---
// CompareTemplate.astro
// Unified template for all "A vs B" comparison pages.
// Usage: <CompareTemplate entry={compareEntry} authorName={authorName} />
// New comparisons only need data in src/data/compare.ts — no HTML to write.

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import { buildComparePageMeta } from '../lib/seo';
import { getRelatedForCompare } from '../lib/related';
import type { CompareEntry } from '../data/compare';

interface Props {
  entry: CompareEntry;
  authorName: string;
  publishDate?: string;
}

const { entry, authorName, publishDate = '2026-06-26' } = Astro.props;
const { productA, productB } = entry;
const meta = buildComparePageMeta(entry, authorName, publishDate);
const related = getRelatedForCompare(productA.name, productB.name, entry.category, entry.slug);

function stars(rating: number): string {
  return '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
}

function winnerLabel(winner: 'A' | 'B' | 'tie'): string {
  if (winner === 'A') return productA.name;
  if (winner === 'B') return productB.name;
  return 'Tie';
}

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'quick-winner', label: 'Quick Winner' },
  { id: 'comparison', label: 'Comparison Table' },
  { id: 'performance', label: 'Performance' },
  { id: 'pricing', label: 'Pricing' },
  { id: 'pros', label: 'Pros' },
  { id: 'cons', label: 'Cons' },
  { id: 'who-should-buy', label: 'Who Should Buy' },
  { id: 'alternatives', label: 'Alternatives' },
  { id: 'faq', label: 'FAQ' },
  { id: 'verdict', label: 'Verdict' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={meta.title}
      description={meta.description}
      ogType="article"
      articleSchema={{ headline: entry.title, description: entry.description, datePublished: publishDate, authorName }}
    />
    <script type="application/ld+json" set:html={JSON.stringify(meta.reviewSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(meta.faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(meta.breadcrumbSchema)} />
    <link rel="canonical" href={meta.canonical} />
    <style>
      .compare-page { max-width: 860px; margin: 0 auto; padding: 48px 24px 64px; min-height: calc(100vh - 200px); }
      .breadcrumb { display: flex; align-items: center; flex-wrap: wrap; gap: 0.3rem; font-size: 0.82rem; color: #666; margin-bottom: 1.5rem; }
      .breadcrumb a { color: #666; text-decoration: none; }
      .breadcrumb a:hover { color: #2563eb; }
      .breadcrumb .sep { color: #aaa; }
      .breadcrumb .current { color: #232f3e; font-weight: 600; }
      .hero { margin-bottom: 2rem; }
      .hero .category-tag { display: inline-block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 4px 12px; border-radius: 12px; margin-bottom: 0.75rem; color: white; }
      .hero h1 { font-size: 2.2rem; line-height: 1.2; margin: 0 0 0.75rem; color: #232f3e; }
      .hero .desc { font-size: 1.1rem; color: #666; line-height: 1.6; margin: 0; }
      .hero-meta { display: flex; align-items: center; gap: 1rem; font-size: 0.85rem; color: #666; margin-top: 1rem; flex-wrap: wrap; }
      .hero-meta a { color: #2563eb; text-decoration: none; font-weight: 600; }
      .hero-meta .dot { width: 4px; height: 4px; border-radius: 50%; background: #aaa; }
      .toc { background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 10px; padding: 1.25rem 1.5rem; margin: 1.5rem 0; }
      .toc h2 { margin-top: 0; font-size: 1.1rem; }
      .toc ol { padding-left: 1.4rem; margin: 0; }
      .toc li { margin: 0.3rem 0; }
      .toc a { color: #2563eb; text-decoration: none; }
      .toc a:hover { text-decoration: underline; }
      .quick-winner { background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(37, 99, 235, 0.02)); border: 1px solid rgba(37, 99, 235, 0.15); border-radius: 14px; padding: 1.5rem; margin: 2rem 0; }
      .quick-winner .label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #2563eb; margin-bottom: 0.5rem; }
      .quick-winner .winner-name { font-size: 1.4rem; font-weight: 800; color: #232f3e; margin-bottom: 0.5rem; }
      .quick-winner .reason { font-size: 0.95rem; color: #374151; line-height: 1.6; margin: 0; }
      .score-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 2rem 0; }
      .score-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem; text-align: center; }
      .score-card .product-name { font-size: 1.1rem; font-weight: 700; color: #232f3e; margin-bottom: 0.5rem; }
      .score-card .score { font-size: 2.5rem; font-weight: 800; line-height: 1; margin-bottom: 0.25rem; }
      .score-card .score .out { font-size: 1rem; font-weight: 500; color: #666; }
      .score-card.a .score { color: #059669; }
      .score-card.b .score { color: #2563eb; }
      .score-card .stars { color: #f59e0b; letter-spacing: 2px; font-size: 1.1rem; }
      h2 { font-size: 1.6rem; margin: 2.5rem 0 1rem; color: #232f3e; scroll-margin-top: 80px; }
      .compare-table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.92rem; }
      .compare-table th, .compare-table td { border: 1px solid #e5e7eb; padding: 0.75rem 1rem; text-align: left; }
      .compare-table th { background: #f3f4f6; font-weight: 700; color: #232f3e; }
      .compare-table th.col-a { color: #059669; }
      .compare-table th.col-b { color: #2563eb; }
      .compare-table td.row-label { font-weight: 600; color: #374151; background: #fafafa; width: 30%; }
      .compare-table .win-a { color: #059669; font-weight: 700; }
      .compare-table .win-b { color: #2563eb; font-weight: 700; }
      .pros-cons-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1rem 0; }
      .pros-cons-block { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.25rem; }
      .pros-cons-block h3 { font-size: 1rem; margin: 0 0 0.75rem; }
      .pros-cons-block.pros h3 { color: #059669; }
      .pros-cons-block.cons h3 { color: #dc2626; }
      .pros-cons-block ul { list-style: none; padding: 0; margin: 0; }
      .pros-cons-block li { font-size: 0.9rem; line-height: 1.6; padding: 0.3rem 0; padding-left: 1.5rem; position: relative; color: #374151; }
      .pros-cons-block.pros li::before { content: '✓'; position: absolute; left: 0; color: #059669; font-weight: bold; }
      .pros-cons-block.cons li::before { content: '✗'; position: absolute; left: 0; color: #dc2626; font-weight: bold; }
      .product-header { font-size: 0.85rem; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.5rem; }
      .who-wins-list { list-style: none; padding: 0; margin: 1rem 0; }
      .who-wins-list li { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 0.5rem; font-size: 0.95rem; }
      .who-wins-list .scenario { flex: 1; color: #374151; }
      .who-wins-list .badge { font-size: 0.8rem; font-weight: 700; padding: 3px 10px; border-radius: 8px; white-space: nowrap; }
      .badge.win-a { color: #059669; background: #ecfdf5; border: 1px solid #a7f3d0; }
      .badge.win-b { color: #2563eb; background: #eff6ff; border: 1px solid #bfdbfe; }
      .badge.win-tie { color: #92400e; background: #fffbeb; border: 1px solid #fde68a; }
      .faq-list details { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 0.75rem; }
      .faq-list summary { font-weight: 700; color: #232f3e; cursor: pointer; font-size: 0.98rem; }
      .faq-list details[open] summary { margin-bottom: 0.75rem; }
      .faq-list details p { margin: 0; font-size: 0.92rem; line-height: 1.7; color: #374151; }
      .related-list { list-style: none; padding: 0; margin: 1rem 0; }
      .related-list li { padding: 0.75rem 0; border-bottom: 1px solid #e5e7eb; }
      .related-list li:last-child { border-bottom: none; }
      .related-list a { color: #2563eb; text-decoration: none; font-weight: 600; font-size: 1rem; }
      .related-list a:hover { text-decoration: underline; }
      .related-list .desc { font-size: 0.85rem; color: #666; margin-top: 0.2rem; }
      .nav-links { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 2.5rem 0; }
      .nav-links a { display: block; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 1rem 1.25rem; text-decoration: none; color: #2563eb; font-weight: 600; font-size: 0.95rem; }
      .nav-links .next { text-align: right; }
      @media (max-width: 640px) { .score-cards, .pros-cons-grid, .nav-links { grid-template-columns: 1fr; } .hero h1 { font-size: 1.6rem; } }
    </style>
  </head>
  <body>
    <Header />
    <div class="compare-page">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <a href="/compare/">Compare</a>
        <span class="sep">/</span>
        <span class="current">{entry.title}</span>
      </nav>

      <div class="hero">
        <span class="category-tag" style={`background: ${entry.color}`}>{entry.category}</span>
        <h1>{entry.title}</h1>
        <p class="desc">{entry.description}</p>
        <div class="hero-meta">
          <span>By <a href={`/authors/${entry.authorSlug}`}>{authorName}</a></span>
          <span class="dot"></span>
          <span>Updated {entry.lastUpdated}</span>
        </div>
      </div>

      <nav class="toc" aria-label="Table of contents">
        <h2>Table of Contents</h2>
        <ol>
          {tocSections.map(s => <li><a href={`#${s.id}`}>{s.label}</a></li>)}
        </ol>
      </nav>

      <h2 id="overview">Overview</h2>
      <p>{entry.description} We compared both products based on product documentation, specifications, and feature analysis to help you decide which is worth your money.</p>

      <div class="quick-winner" id="quick-winner">
        <div class="label">Quick Winner</div>
        <div class="winner-name">
          {entry.quickWinner === 'tie' ? "It's a tie" : winnerLabel(entry.quickWinner)}
        </div>
        <p class="reason">{entry.quickWinnerReason}</p>
      </div>

      <AdSlot position="hero-below" />

      <h2 id="score">Score</h2>
      <div class="score-cards">
        <div class="score-card a">
          <div class="product-name">{productA.name}</div>
          <div class="score">{productA.rating}<span class="out">/5</span></div>
          <div class="stars">{stars(productA.rating)}</div>
        </div>
        <div class="score-card b">
          <div class="product-name">{productB.name}</div>
          <div class="score">{productB.rating}<span class="out">/5</span></div>
          <div class="stars">{stars(productB.rating)}</div>
        </div>
      </div>

      <h2 id="comparison">Comparison Table</h2>
      <table class="compare-table">
        <thead>
          <tr>
            <th>Spec</th>
            <th class="col-a">{productA.name}</th>
            <th class="col-b">{productB.name}</th>
          </tr>
        </thead>
        <tbody>
          {entry.specs.map((spec) => (
            <tr>
              <td class="row-label">{spec.label}</td>
              <td class={spec.winner === 'A' ? 'win-a' : ''}>{spec.productA}</td>
              <td class={spec.winner === 'B' ? 'win-b' : ''}>{spec.productB}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2 id="performance">Performance</h2>
      <p>Performance characteristics are assessed based on product specifications and documented capabilities. {entry.quickWinnerReason}</p>
      <ul class="who-wins-list">
        {entry.whoWins.map(w => (
          <li>
            <span class="scenario">{w.scenario}</span>
            <span class={`badge win-${w.winner}`}>{winnerLabel(w.winner)}</span>
          </li>
        ))}
      </ul>

      <h2 id="pricing">Pricing</h2>
      <table class="compare-table">
        <thead>
          <tr><th>Product</th><th>Price</th><th>Value Score</th></tr>
        </thead>
        <tbody>
          <tr>
            <td class="row-label">{productA.name}</td>
            <td>${productA.price}</td>
            <td class={productA.price < productB.price ? 'win-a' : ''}>{productA.price < productB.price ? 'Better value' : 'Higher price'}</td>
          </tr>
          <tr>
            <td class="row-label">{productB.name}</td>
            <td>${productB.price}</td>
            <td class={productB.price < productA.price ? 'win-b' : ''}>{productB.price < productA.price ? 'Better value' : 'Higher price'}</td>
          </tr>
        </tbody>
      </table>

      <h2 id="pros">Pros</h2>
      <div class="pros-cons-grid">
        <div class="pros-cons-block pros">
          <div class="product-header">{productA.name}</div>
          <h3>Pros</h3>
          <ul>{productA.pros.map(pro => <li>{pro}</li>)}</ul>
        </div>
        <div class="pros-cons-block pros">
          <div class="product-header">{productB.name}</div>
          <h3>Pros</h3>
          <ul>{productB.pros.map(pro => <li>{pro}</li>)}</ul>
        </div>
      </div>

      <h2 id="cons">Cons</h2>
      <div class="pros-cons-grid">
        <div class="pros-cons-block cons">
          <div class="product-header">{productA.name}</div>
          <h3>Cons</h3>
          <ul>{productA.cons.map(con => <li>{con}</li>)}</ul>
        </div>
        <div class="pros-cons-block cons">
          <div class="product-header">{productB.name}</div>
          <h3>Cons</h3>
          <ul>{productB.cons.map(con => <li>{con}</li>)}</ul>
        </div>
      </div>

      <h2 id="who-should-buy">Who Should Buy</h2>
      <ul class="who-wins-list">
        {entry.whoWins.map(w => (
          <li>
            <span class="scenario">{w.scenario}</span>
            <span class={`badge win-${w.winner}`}>{winnerLabel(w.winner)}</span>
          </li>
        ))}
      </ul>

      <h2 id="alternatives">Alternatives</h2>
      <p>Considering other options? Check our <a href="/best/">best-of lists</a> for category-wide rankings, or explore <a href="/alternatives/">alternatives pages</a> for more choices.</p>

      <AdSlot position="content-mid" />

      <h2 id="faq">FAQ</h2>
      <div class="faq-list">
        {entry.faqs.map(faq => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>

      <h2 id="verdict">Final Recommendation</h2>
      <div class="quick-winner">
        <div class="label">Our Pick</div>
        <div class="winner-name">
          {entry.quickWinner === 'tie' ? "It depends on your needs" : winnerLabel(entry.quickWinner)}
        </div>
        <p class="reason">{entry.quickWinnerReason}</p>
      </div>

      {/* Related Reviews */}
      {related.relatedReviews.length > 0 && (
        <>
          <h2 id="related">Related Reviews</h2>
          <ul class="related-list">
            {related.relatedReviews.map(r => (
              <li>
                <a href={r.href}>{r.title}</a>
                <div class="desc">{r.desc}</div>
              </li>
            ))}
          </ul>
        </>
      )}

      {/* Related Best Lists */}
      {related.relatedBests.length > 0 && (
        <>
          <h2 id="related-bests">Best In Category</h2>
          <ul class="related-list">
            {related.relatedBests.map(r => (
              <li>
                <a href={r.href}>{r.title}</a>
                <div class="desc">{r.desc}</div>
              </li>
            ))}
          </ul>
        </>
      )}

      <p><a href="/editorial-policy/">Editorial policy</a></p>

      <AdSlot position="content-end" />
      <AffiliateDisclosure />
    </div>
    <AdSlot position="mobile-bottom" />
    <Footer />
  </body>
</html>
