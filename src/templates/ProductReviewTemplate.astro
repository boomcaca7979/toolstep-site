---
// ProductReviewTemplate.astro
// Unified template for all single-product review pages.
// Usage: <ProductReviewTemplate entry={reviewEntry} authorName={authorName} />
// New reviews only need data in src/data/products.ts — no HTML to write.

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCTACard from '../components/ProductCTACard.astro';
import ReviewMeta from '../components/ReviewMeta.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import AdUnit from '../components/ads/AdUnit.astro';
import { buildProductReviewMeta } from '../lib/seo';
import { getRelatedForReview } from '../lib/related';
import { getAuthor } from '../data/authors';
import { mapCategoryToSlug } from '../data/category-map';
import { getCategoryBySlug } from '../data/categories';
import type { ProductReviewEntry } from '../data/products';

interface Props {
  entry: ProductReviewEntry;
  authorName: string;
  affiliateUrl?: string;
  heroImage?: string;
}

const { entry, authorName, affiliateUrl, heroImage } = Astro.props;
const author = getAuthor(entry.authorSlug);
const meta = buildProductReviewMeta(entry, authorName, author.role);
const related = getRelatedForReview(entry.productName, entry.slug, entry.category, entry.brand, entry.compareSlugs);

// Resolve canonical category for internal linking
const canonicalCatSlug = mapCategoryToSlug(entry.category, entry.productName);
const categoryPage = canonicalCatSlug ? getCategoryBySlug(canonicalCatSlug) : null;
const categoryLink = categoryPage ? `/category/${categoryPage.slug}/` : null;
const categoryLabel = categoryPage ? categoryPage.pluralName : entry.category;

const tocSections = [
  { id: 'quick-verdict', label: 'Quick Verdict' },
  { id: 'testing-summary', label: 'Testing Summary' },
  { id: 'performance', label: 'Performance' },
  { id: 'build-quality', label: 'Build Quality' },
  { id: 'ease-of-use', label: 'Ease of Use' },
  { id: 'value', label: 'Value' },
  { id: 'pros-cons', label: 'Pros & Cons' },
  { id: 'who-should-buy', label: 'Who Should Buy' },
  { id: 'who-should-avoid', label: 'Who Should Avoid' },
  { id: 'alternatives', label: 'Alternatives' },
  { id: 'faq', label: 'FAQ' },
  { id: 'final-verdict', label: 'Final Verdict' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={meta.title}
      description={meta.description}
      ogType="article"
    />
    <script type="application/ld+json" set:html={JSON.stringify(meta.articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(meta.reviewSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(meta.faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(meta.breadcrumbSchema)} />
    <link rel="canonical" href={meta.canonical} />
    <style>
      main { max-width: 820px; margin: 0 auto; padding: 2rem 1rem; line-height: 1.75; color: #333; }
      h1 { color: #232f3e; font-size: 2rem; line-height: 1.2; margin-bottom: 0.5rem; }
      h2 { color: #232f3e; font-size: 1.5rem; margin-top: 2.5rem; margin-bottom: 0.75rem; scroll-margin-top: 80px; }
      h3 { color: #374151; font-size: 1.2rem; margin-top: 1.75rem; margin-bottom: 0.5rem; }
      .meta { color: #666; font-size: 0.9rem; margin-bottom: 0.5rem; }
      .toc { background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 10px; padding: 1.25rem 1.5rem; margin: 1.5rem 0; }
      .toc h2 { margin-top: 0; font-size: 1.1rem; }
      .toc ol { padding-left: 1.4rem; margin: 0; }
      .toc li { margin: 0.3rem 0; }
      .toc a { color: #2563eb; text-decoration: none; }
      .toc a:hover { text-decoration: underline; }
      .verdict-box { background: #eff6ff; border-left: 4px solid #2563eb; border-radius: 0 8px 8px 0; padding: 1rem 1.25rem; margin: 1.5rem 0; }
      .verdict-box strong { color: #1e40af; }
      .rating-box { display: flex; align-items: center; gap: 1rem; background: linear-gradient(135deg, #fff7ed, #ffedd5); border: 1px solid #fed7aa; border-radius: 12px; padding: 1.25rem 1.5rem; margin: 1.5rem 0; }
      .rating-box .score { font-size: 2.5rem; font-weight: 800; color: #ea580c; }
      .rating-box .stars { color: #f59e0b; font-size: 1.2rem; letter-spacing: 2px; }
      .rating-box .label { color: #9a3412; font-weight: 600; }
      .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0; }
      @media (max-width: 600px) { .pros-cons { grid-template-columns: 1fr; } }
      .pros { background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 10px; padding: 1rem 1.25rem; }
      .cons { background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px; padding: 1rem 1.25rem; }
      .pros h3 { color: #047857; margin-top: 0; }
      .cons h3 { color: #b91c1c; margin-top: 0; }
      .pros li::marker { content: '✓ '; color: #059669; font-weight: bold; }
      .cons li::marker { content: '✗ '; color: #dc2626; font-weight: bold; }
      table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.92rem; }
      th, td { border: 1px solid #e5e7eb; padding: 0.65rem 0.75rem; text-align: left; }
      th { background: #f3f4f6; font-weight: 700; color: #374151; }
      .audience { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0; }
      @media (max-width: 600px) { .audience { grid-template-columns: 1fr; } }
      .for { background: #f0fdf4; border-radius: 10px; padding: 1rem 1.25rem; border: 1px solid #bbf7d0; }
      .not-for { background: #fff7ed; border-radius: 10px; padding: 1rem 1.25rem; border: 1px solid #fed7aa; }
      .for h3 { color: #15803d; margin-top: 0; }
      .not-for h3 { color: #c2410c; margin-top: 0; }
      .faq { margin: 1.5rem 0; }
      .faq details { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.9rem 1.1rem; margin-bottom: 0.75rem; }
      .faq summary { font-weight: 700; color: #232f3e; cursor: pointer; }
      .faq details[open] summary { margin-bottom: 0.5rem; }
      .related-section { background: #f8f9fa; border-radius: 10px; padding: 1.25rem 1.5rem; margin: 2rem 0; }
      .related-section h2 { margin-top: 0; }
      .related-section ul { list-style: none; padding: 0; }
      .related-section li { padding: 0.5rem 0; border-bottom: 1px solid #eee; }
      .related-section li:last-child { border-bottom: none; }
      .related-section a { color: #2563eb; text-decoration: none; font-weight: 600; }
      .related-section a:hover { text-decoration: underline; }
      .related-section .desc { color: #666; font-size: 0.88rem; }
      .product-box { background: #f8f9fa; border-radius: 8px; padding: 1.5rem; margin: 2rem 0; }
      .btn { display: inline-block; background: #ff9900; color: #000; padding: 12px 24px; text-decoration: none; border-radius: 4px; font-weight: bold; margin-top: 0.5rem; }
      .btn:hover { background: #e68a00; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>{entry.productName} Review</h1>
      <div class="meta">Updated {entry.lastUpdated} · {entry.testingDuration} testing</div>

      <ReviewMeta
        authorSlug={entry.authorSlug}
        publishDate={entry.publishDate}
        lastUpdated={entry.lastUpdated}
        testingDuration={entry.testingDuration}
        productsTested={entry.productsTested}
      />

      <nav class="toc" aria-label="Table of contents">
        <h2>Table of Contents</h2>
        <ol>
          {tocSections.map(s => <li><a href={`#${s.id}`}>{s.label}</a></li>)}
        </ol>
      </nav>

      <div class="rating-box">
        <div class="score">{entry.ratingValue}</div>
        <div>
          <div class="stars">{'★'.repeat(Math.round(entry.ratingValue))}{'☆'.repeat(5 - Math.round(entry.ratingValue))}</div>
          <div class="label">Our Verdict</div>
        </div>
      </div>

      <h2 id="quick-verdict">Quick Verdict</h2>
      <div class="verdict-box">
        <p>{entry.quickVerdict}</p>
      </div>

      <h2 id="testing-summary">Testing Summary</h2>
      <p>{entry.testingSummary}</p>
      <p>We follow the <a href="/how-we-test/">ToolStep testing protocol</a> for all reviews, measuring performance, build quality, ease of use, and value across real-world scenarios.</p>

      <AdUnit slot="1111111111" format="horizontal" layout="in-article" />

      <h2 id="performance">Performance Evaluation</h2>
      <p>{entry.performance}</p>

      <h2 id="build-quality">Build Quality</h2>
      <p>{entry.buildQuality}</p>

      <h2 id="ease-of-use">Ease of Use</h2>
      <p>{entry.easeOfUse}</p>

      <h2 id="value">Value Analysis</h2>
      <p>{entry.value}</p>

      <h2 id="pros-cons">Pros & Cons</h2>
      <div class="pros-cons">
        <div class="pros">
          <h3>Pros</h3>
          <ul>
            {entry.pros.map(pro => <li>{pro}</li>)}
          </ul>
        </div>
        <div class="cons">
          <h3>Cons</h3>
          <ul>
            {entry.cons.map(con => <li>{con}</li>)}
          </ul>
        </div>
      </div>

      <AdUnit slot="2222222222" format="rectangle" layout="responsive" />

      <h2 id="specs">Specs</h2>
      <table>
        <thead>
          <tr><th>Spec</th><th>Value</th></tr>
        </thead>
        <tbody>
          {entry.specs.map(spec => (
            <tr>
              <td><strong>{spec.label}</strong></td>
              <td>{spec.value}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2 id="who-should-buy">Who Should Buy</h2>
      <div class="audience">
        <div class="for">
          <h3>Best For</h3>
          <ul>
            {entry.bestFor.map(item => <li>{item}</li>)}
          </ul>
        </div>
        <div class="not-for">
          <h3>Not For</h3>
          <ul>
            {entry.notFor.map(item => <li>{item}</li>)}
          </ul>
        </div>
      </div>

      <h2 id="alternatives">Alternatives</h2>
      <ul>
        {entry.alternatives.map(alt => (
          <li><a href={alt.href}>{alt.name}</a> — {alt.desc}</li>
        ))}
      </ul>

      <AdUnit slot="3333333333" format="auto" layout="responsive" />

      <h2 id="faq">FAQ</h2>
      <div class="faq">
        {entry.faqs.map(faq => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>

      <h2 id="final-verdict">Final Verdict</h2>
      <p>{entry.verdict}</p>

      {/* Related Reviews */}
      {related.relatedReviews.length > 0 && (
        <div class="related-section">
          <h2>Related Reviews</h2>
          <ul>
            {related.relatedReviews.map(r => (
              <li>
                <a href={r.href}>{r.title}</a>
                <div class="desc">{r.desc}</div>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Related Best Lists */}
      {related.relatedBests.length > 0 && (
        <div class="related-section">
          <h2>Best In Category</h2>
          <ul>
            {related.relatedBests.map(r => (
              <li>
                <a href={r.href}>{r.title}</a>
                <div class="desc">{r.desc}</div>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Related Comparisons */}
      {related.relatedComparisons.length > 0 && (
        <div class="related-section">
          <h2>Compare With</h2>
          <ul>
            {related.relatedComparisons.map(r => (
              <li>
                <a href={r.href}>{r.title}</a>
                <div class="desc">{r.desc}</div>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Explore Category */}
      {categoryLink && (
        <div class="related-section" style="text-align: center;">
          <h2>Explore More {categoryLabel}</h2>
          <p style="margin-bottom: 0.75rem;">Browse all {categoryLabel.toLowerCase()} reviews, comparisons, and best-of guides on our {categoryLabel} category page.</p>
          <a href={categoryLink} style="display: inline-block; background: #2563eb; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: 600;">View all {categoryLabel.toLowerCase()} →</a>
        </div>
      )}

      <p><a href="/how-we-test/">How we test</a> · <a href="/editorial-policy/">Editorial policy</a></p>

      {/* Amazon CTA at the end */}
      {affiliateUrl && (
        <div class="product-box">
          <h2>Buy {entry.productName}</h2>
          <p>Check the current price on Amazon. As an Amazon Associate, we earn from qualifying purchases.</p>
          <a href={affiliateUrl} class="btn" target="_blank" rel="noopener sponsored">Check Price on Amazon</a>
        </div>
      )}

      <AffiliateDisclosure />
    </main>
    <Footer />
  </body>
</html>
