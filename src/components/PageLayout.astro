---
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description: string;
  /** Breadcrumb items: [{ name, href }] — last item is the current page (no href) */
  breadcrumbs?: Array<{ name: string; href?: string }>;
  /** Last updated date string */
  lastUpdated?: string;
  /** Hide the hero subtitle */
  subtitle?: string;
}

const {
  title,
  description,
  breadcrumbs = [],
  lastUpdated,
  subtitle,
} = Astro.props;

// Build breadcrumb JSON-LD
const itemListElements = breadcrumbs.map((crumb, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: crumb.name,
  ...(crumb.href ? { item: new URL(crumb.href, Astro.site).toString() } : {}),
}));

const breadcrumbSchema = itemListElements.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: itemListElements,
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    <style>
      .eeat-wrap {
        max-width: 760px;
        margin: 0 auto;
        padding: 48px 24px 64px;
        min-height: calc(100vh - 200px);
      }
      .breadcrumb {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.3rem;
        font-size: 0.82rem;
        color: rgb(var(--gray));
        margin-bottom: 1.5rem;
      }
      .breadcrumb a {
        color: rgb(var(--gray));
        text-decoration: none;
        transition: color 0.15s ease;
      }
      .breadcrumb a:hover {
        color: var(--accent);
      }
      .breadcrumb .separator {
        color: rgb(var(--gray-light));
      }
      .breadcrumb .current {
        color: rgb(var(--gray-dark));
        font-weight: 600;
      }
      .eeat-hero {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .eeat-hero h1 {
        font-size: 2.4rem;
        margin: 0 0 0.5rem;
        line-height: 1.2;
      }
      .eeat-hero .subtitle {
        font-size: 1.1rem;
        color: rgb(var(--gray));
        margin: 0;
        line-height: 1.5;
      }
      .last-updated-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
        color: rgb(var(--gray));
        margin-top: 0.75rem;
      }
      .last-updated-row .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #059669;
      }
      .eeat-content h2 {
        font-size: 1.6rem;
        margin: 2.5rem 0 0.75rem;
        color: rgb(var(--black));
      }
      .eeat-content h2:first-child {
        margin-top: 0;
      }
      .eeat-content h3 {
        font-size: 1.2rem;
        margin: 1.5rem 0 0.5rem;
        color: rgb(var(--black));
      }
      .eeat-content p {
        font-size: 1rem;
        line-height: 1.8;
        color: rgb(var(--gray-dark));
        margin: 0 0 1rem;
      }
      .eeat-content ul,
      .eeat-content ol {
        padding-left: 1.5rem;
        margin: 0 0 1.25rem;
      }
      .eeat-content li {
        font-size: 1rem;
        line-height: 1.75;
        color: rgb(var(--gray-dark));
        margin-bottom: 0.5rem;
      }
      .eeat-content strong {
        color: rgb(var(--black));
      }
      .eeat-content a {
        color: var(--accent);
        text-decoration: underline;
      }
      .eeat-content blockquote {
        border-left: 4px solid var(--accent);
        padding: 0.5rem 0 0.5rem 1.25rem;
        margin: 1.5rem 0;
        background: rgba(var(--accent-rgb), 0.04);
        border-radius: 0 8px 8px 0;
        font-size: 1.05rem;
        color: rgb(var(--gray-dark));
        font-style: italic;
      }
      .eeat-content .info-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 12px;
        padding: 1.5rem;
        margin: 1.5rem 0;
        box-shadow: var(--card-shadow);
      }
      .eeat-content .info-card h3 {
        margin-top: 0;
      }
      .eeat-content .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1rem;
        margin: 1.5rem 0;
      }
      .eeat-content .stat-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 12px;
        padding: 1.25rem;
        text-align: center;
      }
      .eeat-content .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: var(--accent);
        line-height: 1;
        margin-bottom: 0.25rem;
      }
      .eeat-content .stat-label {
        font-size: 0.82rem;
        color: rgb(var(--gray));
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 600;
      }
      @media (max-width: 720px) {
        .eeat-wrap {
          padding: 32px 16px 48px;
        }
        .eeat-hero h1 {
          font-size: 1.8rem;
        }
        .eeat-hero .subtitle {
          font-size: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <div class="eeat-wrap" id="main-content">
      {breadcrumbs.length > 0 && (
        <nav class="breadcrumb" aria-label="Breadcrumb">
          {breadcrumbs.map((crumb, i) => (
            <>
              {crumb.href ? (
                <a href={crumb.href}>{crumb.name}</a>
              ) : (
                <span class="current">{crumb.name}</span>
              )}
              {i < breadcrumbs.length - 1 && <span class="separator">/</span>}
            </>
          ))}
        </nav>
      )}

      <div class="eeat-hero">
        <h1>{title}</h1>
        {subtitle && <p class="subtitle">{subtitle}</p>}
        {lastUpdated && (
          <div class="last-updated-row">
            <span class="dot"></span>
            <span>Last updated: {lastUpdated}</span>
          </div>
        )}
      </div>

      <div class="eeat-content">
        <slot />
      </div>
    </div>
    <Footer />
  </body>
</html>
