---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { ADSENSE_CONFIG } from '../config/adsense';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	ogType?: string;
	articleSchema?: {
		headline: string;
		description: string;
		datePublished: string;
		dateModified?: string;
		authorName?: string;
		imageUrl?: string;
	};
	softwareSchema?: {
		name: string;
		description: string;
		url: string;
		applicationCategory: string;
		operatingSystem?: string;
		price?: number;
		priceCurrency?: string;
	};
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = FallbackImage,
	ogType = 'website',
	articleSchema,
	softwareSchema,
} = Astro.props;

const siteOrigin = new URL(Astro.site).origin;
const currentURL = new URL(Astro.url.pathname, Astro.site);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />


<Font cssVariable="--font-atkinson" preload />

<!-- Dark mode: set theme class synchronously to prevent FOUC -->
<script is:inline>
	(function () {
		const stored = localStorage.getItem('theme');
		const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
		if (stored === 'dark' || (!stored && prefersDark)) {
			document.documentElement.classList.add('dark');
		}
	})();
</script>

<!-- Google AdSense — loaded once globally with async to protect CWV -->
{ADSENSE_CONFIG.enabled && (
  <script
    is:inline
    async
    src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CONFIG.client}`}
    crossorigin="anonymous"
  ></script>
)}

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="og:site_name" content={SITE_TITLE} />
<meta name="og:locale" content="en_US" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={new URL(image.src, siteOrigin)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, siteOrigin)} />
<meta name="google-site-verification" content="MaWD-eevKzbPGbi-dPNYwWafiv2nlfvgSJuKBkX8pm8" />

<!-- Schema.org Structured Data: Organization + WebSite -->
<script type="application/ld+json" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"name": "ToolStep",
			"url": siteOrigin,
			"description": "Curated directory of the best online tools for productivity, design, AI, and creativity.",
			"foundingDate": "2026",
		},
		{
			"@type": "WebSite",
			"name": "ToolStep",
			"url": siteOrigin,
			"description": "Curated directory of online tools for productivity, design, AI, and creativity.",
			"potentialAction": {
				"@type": "SearchAction",
				"target": {
					"@type": "EntryPoint",
					"urlTemplate": siteOrigin + "/?q={search_term_string}"
				},
				"query-input": "required name=search_term_string"
			}
		}
	]
})} />

{articleSchema && (
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Article",
		"headline": articleSchema.headline,
		"description": articleSchema.description,
		"datePublished": articleSchema.datePublished,
		"dateModified": articleSchema.dateModified || articleSchema.datePublished,
		"author": {
			"@type": "Person",
			"name": articleSchema.authorName || "ToolStep Team"
		},
		"publisher": {
			"@type": "Organization",
			"name": "ToolStep",
			"url": siteOrigin
		},
		"mainEntityOfPage": { "@type": "WebPage", "@id": String(currentURL) }
	})} />
)}

{softwareSchema && (
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		"name": softwareSchema.name,
		"description": softwareSchema.description,
		"url": softwareSchema.url,
		"applicationCategory": softwareSchema.applicationCategory,
		"operatingSystem": softwareSchema.operatingSystem || "Web, Windows, macOS, iOS, Android",
		"offers": softwareSchema.price !== undefined ? { "@type": "Offer", "price": softwareSchema.price, "priceCurrency": softwareSchema.priceCurrency || "USD" } : undefined
	})} />
)}