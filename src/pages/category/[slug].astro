---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { categories, type Category } from '../../data/categories';
import { categoryMatches } from '../../data/category-map';
import { reviews } from '../../data/reviews';
import { compareData } from '../../data/compare';
import { bestData } from '../../data/best';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

interface Props {
  category: Category;
}

const { category } = Astro.props;
const { slug, name, pluralName, description, color } = category;

const pageTitle = `Best ${pluralName} 2026 — ToolStep`;
const pageDescription = `${description} Compare the best ${pluralName.toLowerCase()} with our in-depth reviews, head-to-head comparisons, and ranked guides.`;
const canonicalURL = new URL(`/category/${slug}/`, Astro.site);

// Filter content by canonical slug using the compatibility map.
// No hardcoding — all matching goes through categoryMatches().
const relatedReviews = reviews
  .filter((r) => categoryMatches(r.category, slug, r.title))
  .slice(0, 8);

const topCompares = compareData
  .filter((c) => categoryMatches(c.category, slug, c.title))
  .slice(0, 6);

const featuredBests = bestData
  .filter((b) => categoryMatches(b.category, slug, b.title))
  .slice(0, 6);

const totalItems = relatedReviews.length + topCompares.length + featuredBests.length;
const isEmptyCategory = totalItems === 0;

// For empty categories, pull related content from sibling categories
// so the page still offers value instead of showing only empty states.
const fallbackReviews = isEmptyCategory
  ? reviews.slice(0, 4)
  : [];
const fallbackCompares = isEmptyCategory
  ? compareData.slice(0, 3)
  : [];
const fallbackBests = isEmptyCategory
  ? bestData.slice(0, 3)
  : [];

// Build FAQ — always at least 2 questions for SEO.
// For empty categories, add generic helpful questions.
const faqs = [
  {
    question: `What are the best ${pluralName.toLowerCase()} in 2026?`,
    answer: description,
  },
  ...(featuredBests[0]?.faqs.slice(0, 2).map((f) => ({
    question: f.question,
    answer: f.answer,
  })) || []),
  ...(isEmptyCategory ? [
    {
      question: `How do I choose the right ${name.toLowerCase()}?`,
      answer: `When choosing a ${name.toLowerCase()}, consider your budget, intended use case, and must-have features. Our team researches and compares the top options to help you make an informed decision — check back soon for dedicated ${pluralName.toLowerCase()} guides.`,
    },
    {
      question: `Does ToolStep review ${pluralName.toLowerCase()}?`,
      answer: `Yes. ToolStep is actively expanding its ${pluralName.toLowerCase()} coverage. In the meantime, browse our other categories or check the latest reviews for related product recommendations.`,
    },
  ] : []),
];

// Schemas
const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalURL.toString(),
  isPartOf: { '@type': 'WebSite', name: 'ToolStep', url: 'https://www.toolstep.top' },
  numberOfItems: totalItems,
  ...(totalItems > 0 ? {
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: [
        ...featuredBests.slice(0, 6).map((b, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: b.title,
          url: new URL(`/best/${b.slug}/`, Astro.site).toString(),
        })),
        ...topCompares.slice(0, 6).map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1 + featuredBests.length,
          name: c.title,
          url: new URL(`/compare/${c.slug}/`, Astro.site).toString(),
        })),
        ...relatedReviews.slice(0, 8).map((r, i) => ({
          '@type': 'ListItem',
          position: i + 1 + featuredBests.length + topCompares.length,
          name: r.title,
          url: new URL(r.href, Astro.site).toString(),
        })),
      ],
    },
  } : {}),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toolstep.top/' },
    { '@type': 'ListItem', position: 2, name: 'Categories', item: 'https://www.toolstep.top/#categories' },
    { '@type': 'ListItem', position: 3, name: pluralName, item: canonicalURL.toString() },
  ],
};

const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;

// Sibling categories for navigation
const siblingCategories = categories.filter((c) => c.slug !== slug).slice(0, 10);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<link rel="canonical" href={canonicalURL} />
		<script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
		<style>
			.page-hero {
				max-width: 1200px;
				margin: 0 auto;
				padding: 48px 24px 24px;
			}
			.breadcrumb {
				font-size: 13px;
				color: rgb(var(--gray));
				margin-bottom: 12px;
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.page-hero h1 {
				font-size: 36px;
				font-weight: 800;
				margin: 0 0 12px 0;
				color: rgb(var(--gray-dark));
				letter-spacing: -0.02em;
			}
			.page-hero p {
				font-size: 17px;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.6;
				max-width: 720px;
			}
			.page-hero .count-badge {
				display: inline-block;
				margin-top: 16px;
				padding: 6px 14px;
				border-radius: 20px;
				background: rgba(var(--accent-rgb), 0.1);
				color: var(--accent);
				font-size: 13px;
				font-weight: 600;
			}

			.section-block {
				max-width: 1200px;
				margin: 0 auto;
				padding: 28px 24px;
			}
			.section-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 18px;
				gap: 12px;
				flex-wrap: wrap;
			}
			.section-head h2 {
				margin: 0;
				font-size: 24px;
				font-weight: 700;
				color: rgb(var(--gray-dark));
			}
			.view-all-link {
				font-size: 14px;
				font-weight: 600;
				color: var(--accent);
				text-decoration: none;
				white-space: nowrap;
			}
			.view-all-link:hover {
				text-decoration: underline;
			}

			.cards-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 16px;
			}
			.content-card {
				display: flex;
				flex-direction: column;
				gap: 8px;
				padding: 18px;
				border-radius: 12px;
				border: 1px solid var(--card-border);
				background: var(--card-bg);
				text-decoration: none;
				transition: all 0.2s ease;
				box-shadow: var(--card-shadow);
			}
			.content-card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
				box-shadow: var(--card-shadow-hover);
			}
			.card-tag {
				display: inline-block;
				align-self: flex-start;
				font-size: 11px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				padding: 3px 8px;
				border-radius: 6px;
				color: white;
			}
			.card-title {
				font-size: 16px;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				margin: 0;
				line-height: 1.3;
			}
			.card-desc {
				font-size: 13px;
				color: rgb(var(--gray));
				line-height: 1.5;
				margin: 0;
			}

			.empty-section {
				padding: 40px 20px;
				text-align: center;
				color: rgb(var(--gray));
				font-size: 14px;
				border: 1px dashed var(--card-border);
				border-radius: 12px;
			}

			.faq-block {
				max-width: 800px;
				margin: 0 auto;
				padding: 28px 24px;
			}
			.faq-block h2 {
				font-size: 24px;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				margin: 0 0 18px 0;
			}
			.faq-item {
				border-bottom: 1px solid var(--card-border);
				padding: 16px 0;
			}
			.faq-item h3 {
				font-size: 16px;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				margin: 0 0 8px 0;
			}
			.faq-item p {
				font-size: 14px;
				color: rgb(var(--gray));
				line-height: 1.6;
				margin: 0;
			}

			.sibling-cats {
				max-width: 1200px;
				margin: 0 auto;
				padding: 20px 24px 40px;
			}
			.sibling-cats h3 {
				font-size: 14px;
				font-weight: 600;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin: 0 0 12px 0;
			}
			.sibling-list {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
			}
			.sibling-list a {
				padding: 8px 14px;
				border-radius: 8px;
				border: 1px solid var(--card-border);
				background: var(--card-bg);
				color: rgb(var(--gray-dark));
				font-size: 13px;
				font-weight: 500;
				text-decoration: none;
				transition: border-color 0.2s ease;
			}
			.sibling-list a:hover {
				border-color: var(--accent);
				color: var(--accent);
			}

			@media (max-width: 768px) {
				.page-hero {
					padding: 32px 16px 20px;
				}
				.page-hero h1 {
					font-size: 28px;
				}
				.section-block {
					padding: 20px 16px;
				}
				.cards-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<section class="page-hero">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a> › <a href="/#categories">Categories</a> › {pluralName}
			</nav>
			<h1>Best {pluralName} 2026</h1>
			<p>{description}</p>
			<span class="count-badge">{totalItems} resources · {featuredBests.length} guides · {topCompares.length} comparisons · {relatedReviews.length} reviews</span>
			{isEmptyCategory && (
				<p style="margin-top: 12px; font-size: 14px; color: rgb(var(--gray));">
					We're building out {pluralName.toLowerCase()} coverage. In the meantime, here are popular picks from other categories.
				</p>
			)}
		</section>

		{/* ===== Featured Best Guides ===== */}
		<section class="section-block">
			<div class="section-head">
				<h2>Best {pluralName} Guides</h2>
				<a class="view-all-link" href="/best/">All best guides →</a>
			</div>
			{featuredBests.length > 0 ? (
				<div class="cards-grid">
					{featuredBests.map((b) => (
						<a class="content-card" href={`/best/${b.slug}/`}>
							<span class="card-tag" style={`background: ${b.color}`}>{b.category}</span>
							<h3 class="card-title">{b.title}</h3>
							<p class="card-desc">{b.description}</p>
						</a>
					))}
				</div>
			) : isEmptyCategory && fallbackBests.length > 0 ? (
				<div class="cards-grid">
					{fallbackBests.map((b) => (
						<a class="content-card" href={`/best/${b.slug}/`}>
							<span class="card-tag" style={`background: ${b.color}`}>{b.category}</span>
							<h3 class="card-title">{b.title}</h3>
							<p class="card-desc">{b.description}</p>
						</a>
					))}
				</div>
			) : (
				<div class="empty-section">No best guides for this category yet. <a href="/best/">Browse all guides →</a></div>
			)}
		</section>

		{/* ===== Top Comparisons ===== */}
		<section class="section-block">
			<div class="section-head">
				<h2>Top {pluralName} Comparisons</h2>
				<a class="view-all-link" href="/compare/">All comparisons →</a>
			</div>
			{topCompares.length > 0 ? (
				<div class="cards-grid">
					{topCompares.map((c) => (
						<a class="content-card" href={`/compare/${c.slug}/`}>
							<span class="card-tag" style={`background: ${c.color}`}>{c.category}</span>
							<h3 class="card-title">{c.title}</h3>
							<p class="card-desc">{c.description}</p>
						</a>
					))}
				</div>
			) : isEmptyCategory && fallbackCompares.length > 0 ? (
				<div class="cards-grid">
					{fallbackCompares.map((c) => (
						<a class="content-card" href={`/compare/${c.slug}/`}>
							<span class="card-tag" style={`background: ${c.color}`}>{c.category}</span>
							<h3 class="card-title">{c.title}</h3>
							<p class="card-desc">{c.description}</p>
						</a>
					))}
				</div>
			) : (
				<div class="empty-section">No comparisons for this category yet. <a href="/compare/">Browse all comparisons →</a></div>
			)}
		</section>

		{/* ===== Related Reviews ===== */}
		<section class="section-block">
			<div class="section-head">
				<h2>{pluralName} Reviews</h2>
				<a class="view-all-link" href="/reviews/">All reviews →</a>
			</div>
			{relatedReviews.length > 0 ? (
				<div class="cards-grid">
					{relatedReviews.map((r) => (
						<a class="content-card" href={r.href}>
							<span class="card-tag" style={`background: ${r.color}`}>{r.category}</span>
							<h3 class="card-title">{r.title}</h3>
							<p class="card-desc">{r.desc}</p>
						</a>
					))}
				</div>
			) : isEmptyCategory && fallbackReviews.length > 0 ? (
				<div class="cards-grid">
					{fallbackReviews.map((r) => (
						<a class="content-card" href={r.href}>
							<span class="card-tag" style={`background: ${r.color}`}>{r.category}</span>
							<h3 class="card-title">{r.title}</h3>
							<p class="card-desc">{r.desc}</p>
						</a>
					))}
				</div>
			) : (
				<div class="empty-section">No reviews for this category yet. <a href="/reviews/">Browse all reviews →</a></div>
			)}
		</section>

		{/* ===== FAQ ===== */}
		{faqs.length > 0 && (
			<section class="faq-block">
				<h2>Frequently Asked Questions</h2>
				{faqs.map((f) => (
					<div class="faq-item">
						<h3>{f.question}</h3>
						<p>{f.answer}</p>
					</div>
				))}
			</section>
		)}

		{/* ===== Related Categories ===== */}
		<section class="sibling-cats">
			<h3>Related Categories</h3>
			<div class="sibling-list">
				{siblingCategories.map((c) => (
					<a href={`/category/${c.slug}/`} title={`Browse ${c.pluralName.toLowerCase()} guides, reviews, and comparisons`}>{c.pluralName}</a>
				))}
			</div>
			<div class="all-categories-link" style="margin-top: 14px;">
				<a href="/category/" style="font-size: 13px; color: var(--accent); font-weight: 600; text-decoration: none;">View all categories →</a>
			</div>
		</section>

		{/* ===== Quick Browse ===== */}
		<section class="section-block" style="padding-top: 0;">
			<div style="background: rgba(var(--accent-rgb), 0.03); border: 1px solid rgba(var(--accent-rgb), 0.12); border-radius: 12px; padding: 20px 24px; text-align: center;">
				<h3 style="margin: 0 0 8px 0; font-size: 16px; font-weight: 700; color: rgb(var(--gray-dark));">Browse More on ToolStep</h3>
				<p style="margin: 0 0 12px 0; font-size: 13px; color: rgb(var(--gray));">Explore our complete directory of reviews, comparisons, and best-of guides.</p>
				<div style="display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;">
					<a href="/reviews/" style="font-size: 13px; color: var(--accent); font-weight: 600; text-decoration: none;">All Reviews →</a>
					<a href="/compare/" style="font-size: 13px; color: var(--accent); font-weight: 600; text-decoration: none;">All Comparisons →</a>
					<a href="/best/" style="font-size: 13px; color: var(--accent); font-weight: 600; text-decoration: none;">All Best Guides →</a>
					<a href="/tools/" style="font-size: 13px; color: var(--accent); font-weight: 600; text-decoration: none;">Tools Directory →</a>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
