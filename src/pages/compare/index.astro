---
import PageLayout from '../../components/PageLayout.astro';
import { compareData } from '../../data/compare';

const pageTitle = 'Compare — ToolStep Product Comparisons';
const pageDescription = 'Side-by-side product comparisons tested by our team. Standing desks, chairs, keyboards, mice, docks, and more.';
const lastUpdated = 'June 2026';

// Group by category preserving order
const categories: { name: string; color: string; items: typeof compareData }[] = [];
for (const entry of compareData) {
  let group = categories.find(c => c.name === entry.category);
  if (!group) {
    group = { name: entry.category, color: entry.color, items: [] };
    categories.push(group);
  }
  group.items.push(entry);
}
---

<PageLayout
  title="Product Comparisons"
  description={pageDescription}
  subtitle="50 side-by-side comparisons across hardware and software. Each page has a quick winner, full spec table, pros/cons, and who wins each scenario."
  lastUpdated={lastUpdated}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Compare' },
  ]}
>
  <div class="compare-categories">
    {categories.map((cat) => (
      <section class="category-section">
        <h2>
          <span class="category-dot" style={`background: ${cat.color}`}></span>
          {cat.name}
          <span class="category-count">{cat.items.length}</span>
        </h2>
        <div class="compare-grid">
          {cat.items.map((entry) => (
            <a href={`/compare/${entry.slug}/`} class="compare-card">
              <div class="card-title">{entry.title}</div>
              <div class="card-desc">{entry.description}</div>
              <div class="card-winner">
                {entry.quickWinner === 'tie' ? (
                  <span class="winner-tie">Tie</span>
                ) : entry.quickWinner === 'A' ? (
                  <span class="winner-a">{entry.productA.name} wins</span>
                ) : (
                  <span class="winner-b">{entry.productB.name} wins</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</PageLayout>

<style>
  .compare-categories {
    margin: 1rem 0;
  }
  .category-section {
    margin-bottom: 2.5rem;
  }
  .category-section h2 {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.5rem;
    margin: 0 0 1rem;
    color: rgb(var(--black));
  }
  .category-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .category-count {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgb(var(--gray));
    background: rgba(var(--gray-light), 60%);
    padding: 2px 10px;
    border-radius: 12px;
    margin-left: 0.25rem;
  }
  .compare-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .compare-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .compare-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }
  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: rgb(var(--black));
    line-height: 1.3;
  }
  .card-desc {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    line-height: 1.5;
    flex: 1;
  }
  .card-winner {
    margin-top: 0.5rem;
  }
  .winner-a, .winner-b {
    font-size: 0.78rem;
    font-weight: 600;
    color: #059669;
    background: #ecfdf5;
    padding: 3px 10px;
    border-radius: 8px;
    border: 1px solid #a7f3d0;
  }
  .winner-b {
    color: #2563eb;
    background: #eff6ff;
    border-color: #bfdbfe;
  }
  .winner-tie {
    font-size: 0.78rem;
    font-weight: 600;
    color: #92400e;
    background: #fffbeb;
    padding: 3px 10px;
    border-radius: 8px;
    border: 1px solid #fde68a;
  }
  @media (max-width: 720px) {
    .compare-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
