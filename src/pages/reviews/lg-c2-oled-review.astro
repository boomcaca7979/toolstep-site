  <body>
    <Header />
    <main>
      <h1>LG C2 42&Prime; OLED Review</h1>
      <div class="meta">Updated June 2026 · 13 min read</div>
      <div class="author">By <a href={`/authors/${authorSlug}`}>{author}</a></div>

      <Image src={heroImg} alt="LG C2 42 inch OLED TV displaying a vibrant HDR scene" width={1200} height={600} loading="eager" fetchpriority="high" class="hero-img" />

