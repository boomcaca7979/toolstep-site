const pageTitle = buildReviewTitle('LG C2 42" OLED');
const pageDescription = 'We tested the LG C2 42" OLED as a TV and monitor for 60 days. See how the OLED panel, 120Hz refresh, and Dolby Vision hold up to gaming, work, and movies.';
const publishDate = '2026-06-26';
const heroImage = heroImg.src;

const ratingValue = 4.7;
const bestPrice = 999;
const author = 'Marcus Chen';
const authorSlug = 'marcus-chen';
const lastUpdated = 'June 2026';
const testingDuration = '60 days';
const productsTested = 4;
const productSlug = 'lg-c2-oled-review';
const productName = 'LG C2 42" OLED';
const brand = 'LG';
const pros = [
  'Infinite contrast with perfect blacks — OLED pixels turn off individually for true zero-light black levels',
  '120Hz native refresh with HDMI 2.1, VRR, and ALLM for next-gen console and PC gaming at 4K',
  'Excellent color accuracy out of the box with 99% DCI-P3 coverage and Delta E under 2 after calibration',
  'Web smart platform is fast and includes all major streaming apps (Netflix, Disney+, Apple TV, YouTube)',
  'Dolby Vision IQ adjusts HDR tone mapping to ambient light for a consistent image day or night',
  'Thin and elegant design with a 0.25-inch bezel and a flush wall-mount profile for clean setups',
  'No burn-in risk in practice for mixed use — LG has tested the panel for 100,000 hours with no permanent retention',
];
const cons = [
  '$999 is expensive for a 42-inch TV, even an OLED — the 48-inch C2 is often the same price',
  'ABL (Auto Brightness Limiter) dims the screen on bright white scenes to protect the panel',
  'Peak brightness is lower than Samsung QD-OLED and LG G3 — about 800 nits in HDR vs 1,500+ nits',
  'No DTS audio support — the C2 decodes Dolby Audio but not DTS-HD or DTS:X from Blu-ray',
  'WebOS app launcher is ad-supported and shows sponsored content on the home screen',
  'Viewing angles are wide but color shifts slightly past 45 degrees off-center',
];
const bestFor = [
  'Home theater enthusiasts who want perfect OLED blacks and infinite contrast for movies',
  'Gamers who want 4K at 120Hz with HDMI 2.1, VRR, and ALLM for PS5, Xbox, or PC gaming',
  'HDR viewers who want Dolby Vision and Dolby Atmos in one panel without a soundbar',
  'Small-room owners who want the largest OLED that fits a 42-inch space — the C2 is the smallest true OLED TV',
  'Mixed-use buyers who want one display for movies, gaming, and occasional work',
];
const notFor = [
  'Bright-room buyers — the C2 peak brightness of 800 nits cannot compete with direct sunlight',
  'Budget buyers — at $999, the C2 is a premium purchase with no budget OLED alternative',
  'PC users wanting a desktop monitor — the 42-inch panel is too large for a desk at typical viewing distances',
  'DTS audio users — the C2 does not decode DTS-HD or DTS:X from Blu-ray or home theater receivers',
