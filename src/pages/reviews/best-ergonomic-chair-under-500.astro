const faqs = [
  { q: 'What is the best ergonomic chair under $500?', a: 'The Branch Ergonomic Chair is our top pick. At $345 it offers adjustable lumbar support (height and depth), a breathable mesh back, 4D armrests, and a 7-year warranty — features that usually cost $1,000+ in premium chairs.' },
