const publishDate = '2026-06-26';
const heroImage = heroImg.src;

const ratingValue = 4.4;
const bestPrice = 345;
const author = 'Toolwise Team';

const faqs = [
  { q: 'Is the Branch Ergonomic Chair worth $345?', a: 'Yes, if you sit 6 or more hours per day. It outperforms every chair under $200 on lumbar support and breathability, and it undercuts premium chairs like the Herman Miller Aeron by $600+. For occasional use under 4 hours a day, a cheaper chair is fine.' },
  { q: 'How does the Branch Ergonomic Chair compare to the Herman Miller Aeron?', a: 'The Aeron is meaningfully better on every metric — build quality, adjustability, and 12-year warranty versus Branch\'s 7 years. But the Aeron costs $1,395 and the Branch costs $345. For most home office workers, the Branch delivers 80 percent of the Aeron experience for a quarter of the price.' },
  { q: 'Is the Branch Ergonomic Chair good for tall people?', a: 'It fits users up to about 6\'2". The seat depth is 18 inches and the backrest reaches 21 inches at maximum height. If you are over 6\'2", the seat will feel short and the headrest sits behind your shoulders rather than your head.' },
