  <body>
    <Header />
    <main>
      <h1>Branch Ergonomic Chair Review</h1>
      <div class="meta">Updated June 2026 · 11 min read</div>
      <div class="author">By {author}</div>

      <img src={heroImage} alt="Branch ergonomic chair with mesh back in a bright home office" class="hero-img" loading="lazy" width="1280" height="720" />

      <nav class="toc" aria-label="Table of contents">
