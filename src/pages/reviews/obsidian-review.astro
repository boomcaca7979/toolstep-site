  { title: 'Linear vs Jira', href: '/reviews/linear-vs-jira/', desc: 'Team project tracking — when notes outgrow personal use.' },
  { title: 'Google Drive vs Dropbox vs OneDrive', href: '/reviews/google-drive-vs-dropbox-vs-onedrive/', desc: 'Cloud storage to back up your vault for free.' },
  { title: 'Best Password Managers 2026', href: '/reviews/best-password-managers-2026/', desc: 'Another local-first tool category worth knowing.' },
];

const prevPost = { title: 'Notion vs Obsidian', href: '/reviews/notion-vs-obsidian/' };
const nextPost = { title: 'Claude vs ChatGPT', href: '/reviews/claude-vs-chatgpt/' };
