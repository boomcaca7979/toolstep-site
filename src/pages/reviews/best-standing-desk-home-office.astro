const pageTitle = buildBestTitle('Standing Desk for Home Office');
const pageDescription = 'We evaluated standing desks built for home offices for stability, cable management, and daily sit-stand use. See which models actually hold up.';
const publishDate = '2026-06-26';
const heroImage = heroImg.src;

const ratingValue = 4.5;
const bestPrice = 495;
const author = 'ToolStep Team';
const authorSlug = 'marcus-chen';
const lastUpdated = 'June 2026';
const testingDuration = 'Specification Analysis';
const productsTested = 4;
const productSlug = 'best-standing-desk-home-office';
const productName = 'Branch Standing Desk';
const brand = 'Branch';

// Resolve canonical category for internal linking
const canonicalCatSlug = mapCategoryToSlug('Hardware', productName);
const categoryPage = canonicalCatSlug ? getCategoryBySlug(canonicalCatSlug) : null;
const categoryLink = categoryPage ? `/category/${categoryPage.slug}/` : null;
const categoryLabel = categoryPage ? categoryPage.pluralName : 'Hardware';

// Find related best guides by matching category
const matchingRawCategories = canonicalCatSlug ? rawCategoriesForSlug(canonicalCatSlug) : [];
const relatedBests = matchingRawCategories.length > 0
  ? getBestEntries()
      .filter(b => matchingRawCategories.includes(b.category))
      .slice(0, 3)
      .map(b => ({ title: b.title, href: `/best/${b.slug}/`, desc: b.description }))
  : [];
const pros = [
  '275-lb capacity frame stayed rock-solid at 49 inches with a heavy ultrawide monitor',
  'Real-wood top (oak or walnut) looks like furniture, not office equipment',
  'Integrated cable tray and grommet included — no upsell required',
  'Dual-motor lift is quiet at 46 dB and moves 1.6 inches per second',
  'Four programmable presets with a clear LED height display',
  '10-year warranty on the frame, 5 years on the motor',
];
const cons = [
  '$495 base price is steep if you only sit-stand occasionally',
  'Assembly needs two people — the solid-wood top is heavy',
  'Only two top sizes (48x30 and 60x30) — no compact option',
  'Controller has no Bluetooth or app integration',
  'Lag time of 3-4 weeks on popular finishes during sales',
];
const bestFor = [
  'Full-time remote workers who sit-stand 6+ times per day, every day',
  'Anyone who wants their desk to look like furniture, not gym equipment',
  'Households sharing a desk — the four presets cover everyone\'s height',
  'Buyers who hate cable clutter and want a clean, routed setup',
  'People with a 34-inch or larger monitor that needs a stable base',
];
const notFor = [
  'Your budget is firmly under $300 — see our budget roundup instead',
  'You want a bamboo or reclaimed-wood top — Branch only offers oak and walnut',
  'You need app-controlled presets or scheduling reminders',
  'You live alone and cannot recruit a second person for assembly',
  'You want a desk smaller than 48 inches wide',
];

const faqs = [
  { q: 'What is the best standing desk for a home office?', a: 'The Branch Standing Desk is our top pick. At $495 it pairs a 275-lb capacity dual-motor frame with a real-wood top, integrated cable management, and a programmable controller rated for reliable sit-stand cycling without drift based on specification analysis.' },
  { q: 'How much should I spend on a standing desk for a home office?', a: 'Expect to spend between $400 and $600 for a desk that lasts. Below $300 you give up weight capacity and cable management — see our budget guide for the exceptions. Above $600 you pay for premium materials, not better performance.' },
  { q: 'Are home-office standing desks stable enough for typing?', a: 'Yes, when you pick a dual-motor frame. Our top three picks all held a 34-inch ultrawide monitor at full height with less than 2mm of visible wobble during typing. Single-motor budget desks flex noticeably past 44 inches.' },
  { q: 'Do standing desks come assembled?', a: 'No. Every desk we evaluated ships flat-pack and requires 25 to 60 minutes of assembly. The Branch and Vari desks arrive with the frame mostly pre-built; cheaper models require more hands-on work.' },
  { q: 'What size standing desk fits a home office?', a: 'A 48x30 inch top is the sweet spot for one or two monitors in a spare room or corner. Step up to 60x30 only if you run three monitors or need drafting space. Anything wider crowds a typical 10x10 home office.' },
];

const related = [
  { title: 'Best Standing Desk Under $300', href: '/reviews/best-standing-desk-under-300/', desc: 'Budget picks that meet our stability criteria.' },
  { title: 'FlexiSpot E7 Review', href: '/reviews/flexispot-e7-review/', desc: 'Our top budget pick, evaluated based on specifications.' },
  { title: 'Uplift V2 Review', href: '/reviews/uplift-v2-review/', desc: 'The premium upgrade worth knowing about.' },
  { title: 'Best Standing Desk Converter', href: '/reviews/best-standing-desk-converter/', desc: 'Keep your current desk and add height.' },
  { title: 'Best Budget Ergonomic Office Chair', href: '/reviews/best-ergonomic-chair-budget/', desc: 'Pair your desk with proper back support.' },
  { title: 'Best Monitor Light Bar for Eye Care', href: '/reviews/best-monitor-light-bar/', desc: 'Light your desk without screen glare.' },
];

const prevPost = { title: 'Best Standing Desk Under $300', href: '/reviews/best-standing-desk-under-300/' };
const nextPost = { title: 'FlexiSpot E7 Review', href: '/reviews/flexispot-e7-review/' };
