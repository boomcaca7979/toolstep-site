          <a href={categoryLink} style="display: inline-block; background: #2563eb; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: 600;">View all {categoryLabel.toLowerCase()} →</a>
        </div>
      )}

      <nav class="nav-links" aria-label="Post navigation">
        <a href={prevPost.href}>
          <span class="label">← Previous</span>
          {prevPost.title}
        </a>
        <a href={nextPost.href} class="next">
          <span class="label">Next →</span>
          {nextPost.title}
        </a>
      </nav>

      <AffiliateDisclosure />
    </main>
    <StickyCTA productName={productName} rating={ratingValue} price={bestPrice} slug={productSlug} />
    <Footer />
  </body>
</html>
