  <body>
    <Header />
    <main>
      <h1>Best Standing Desk for Home Office</h1>
      <div class="meta">Updated June 2026 · 13 min read</div>
      <div class="author">By <a href={`/authors/${authorSlug}`}>{author}</a></div>

