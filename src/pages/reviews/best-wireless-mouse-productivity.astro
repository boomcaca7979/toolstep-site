const productSlug = 'best-wireless-mouse-productivity';
const productName = 'Logitech MX Master 3S';
const brand = 'Logitech';
const pros = [
  'MagSpeed scroll wheel shifts from ratchet to free-spin in under a second',
  '8000 DPI sensor tracks reliably on glass, cloth, and glossy surfaces',
  'Flow lets you control three computers with one cursor — including file drag',
  'Quiet clicks are 90% quieter than the older MX Master 3',
  'USB-C charging works while in use; 1-minute charge gives 3 hours',
  'Thumb wheel handles horizontal scroll without modifier keys',
];
const cons = [
  '$99 is steep when a $40 M720 covers 80% of the same features',
  'The humpback shape favors palm grip; claw grip users feel cramped',
  'Logi Options+ software is required for Flow and per-app button mapping',
  'Right-handed only — lefties are out of luck',
  'At 141 g it is heavier than gaming mice some users are used to',
];
const bestFor = [
  'Knowledge workers who spend 6+ hours a day at the computer',
  'Anyone switching between two or three machines — Mac, PC, or iPad',
  'People who scroll through long PDFs, spreadsheets, or code reviews daily',
  'Palm-grip users with medium to large hands (7 to 8.5 inches)',
  'Anyone sharing an open office where loud clicks would annoy coworkers',
];
const notFor = [
  'You are a left-handed mouse user — there is no lefty version',
  'You mainly game; this is too heavy and the polling rate is too low',
  'You use a claw or fingertip grip — the humpback shape fights you',
  'Your budget tops out at $40 — get the M720 Triathlon instead',
  'You need a mouse for a tablet-only setup with no second device',
];

const faqs = [
  { q: 'Is the Logitech MX Master 3S worth $99?', a: 'Yes, if you spend 4+ hours a day at a computer. The MagSpeed scroll wheel, 8000 DPI sensor, and Flow cross-computer control solve problems that cheaper mice cannot. For light users, the $40 M720 delivers 80% of the value at half the price.' },
  { q: 'Does the MX Master 3S work on glass?', a: 'Yes. Logitech upgraded the sensor to track on glass and other reflective surfaces where the older MX Master 3 struggled. We tested it on a tempered glass desk and a glossy white mat with no skipping.' },
  { q: 'Can I use one MX Master 3S across three computers?', a: 'Yes, via Logitech Flow. You pair it over Bluetooth or the Unifying receiver with up to three devices, then enable Flow in Logi Options+ to move the cursor across screens — including clipboard and file drag-and-drop between PCs.' },
