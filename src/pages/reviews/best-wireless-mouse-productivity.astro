      <div class="product-box">
        <h2>🏆 Logitech MX Master 3S</h2>
        <ul>
          <li><strong>8000 DPI sensor</strong> — tracks on glass and glossy surfaces</li>
          <li><strong>MagSpeed scroll</strong> — ratchet and free-spin in one wheel</li>
          <li><strong>Flow across 3 devices</strong> — one cursor, three computers</li>
          <li><strong>Quiet clicks</strong> — 90% quieter than the older MX Master 3</li>
          <li><strong>70-day battery</strong> — USB-C charging while in use</li>
        </ul>
        <a href="https://www.amazon.com/s?k=logitech+mx+master+3s&tag=toolwise20-20" class="btn" target="_blank" rel="noopener sponsored">Check Current Price on Amazon</a>
      </div>

      <section class="related">
        <h2>Related Reviews</h2>
        <ul>
          {related.map((r) => (
            <li>
              <a href={r.href}>{r.title}</a>
              <div class="desc">{r.desc}</div>
            </li>
          ))}
        </ul>
      </section>

      <nav class="nav-links" aria-label="Post navigation">
        <a href={prevPost.href}>
          <span class="label">← Previous</span>
          {prevPost.title}
        </a>
        <a href={nextPost.href} class="next">
          <span class="label">Next →</span>
          {nextPost.title}
        </a>
      </nav>

      <AffiliateDisclosure />
    </main>
    <StickyCTA productName={productName} rating={ratingValue} price={bestPrice} slug={productSlug} />
    <Footer />
  </body>
</html>
