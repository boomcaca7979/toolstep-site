  'Separate one-time purchases for Mac ($49.99), iPad ($19.99), and iPhone ($9.99) add up to $80 for all platforms',
  'No free tier and no trial — you pay per platform before you can test the full app',
];

const bestFor = [
  'Apple-only users who want a beautiful, fast, native task manager for Mac, iPhone, and iPad',
  'Personal productivity practitioners who follow GTD (Getting Things Done) and want areas, projects, and contexts',
  'Freelancers and solopreneurs who manage personal tasks and projects without team collaboration needs',
  'Users who want a one-time purchase instead of a recurring subscription for their task management',
  'People who value design and want an app that feels like a polished native Apple experience',
];
const notFor = [
  'Windows or Android users — Things 3 is Apple-only with no web version',
  'Teams and anyone who needs shared projects, comments, or real-time collaboration — Things 3 is single-user only',
  'Project managers who need Gantt charts, dependencies, kanban boards, or custom fields',
