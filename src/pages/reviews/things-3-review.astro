const pageTitle = buildReviewTitle('Things 3 for Mac');
const pageDescription = 'We tested the Things 3 task manager for 60 days on Mac and iOS. See how the award-winning design, GTD workflow, Things Cloud sync, and one-time purchase hold up for personal productivity.';
const publishDate = '2026-06-26';
const heroImage = heroImg.src;

const ratingValue = 4.7;
const bestPrice = 49.99;
const author = 'ToolStep Team';
const authorSlug = 'toolstep-team';
const lastUpdated = 'June 2026';
const testingDuration = '60 days';
const productsTested = 5;
const productSlug = 'things-3-review';
const productName = 'Things 3 for Mac';
const brand = 'Cultured Code';
const pros = [
  'Award-winning design with thoughtful typography, smooth animations, and a clean three-pane layout that feels native on Mac and iOS',
  'One-time purchase per platform — no subscription, no recurring fees, no feature gates over time',
  'Natural language quick entry parses "tomorrow at 9pm" and "every Friday" into properly dated and recurring tasks',
  'Project areas and headings let you organize large projects hierarchically with collapsible sections and per-section checklists',
  'Things Cloud sync is fast and reliable across Mac, iPhone, iPad, and Apple Watch with no setup beyond signing in',
  'Today, Upcoming, Anytime, Someday, and Logbook views cover the full GTD workflow without forcing a single workflow',
  'Magic Plus gesture on iPad and iPhone lets you drag a new task into any list with one finger, no menu navigation',
];
const cons = [
  'Apple-only — there is no Windows, Android, or web version of Things 3',
  'No real-time collaboration or shared projects — Things 3 is a single-user app only',
  'No kanban board or calendar view — tasks live in lists, not cards on a board',
