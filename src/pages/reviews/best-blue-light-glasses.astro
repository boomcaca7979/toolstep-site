const pageDescription = 'We evaluated 7 blue light glasses based on lens transmission specs, frame weight, and comfort ratings. FEIYOLD led on 95% blocking and 18g weight.';
const publishDate = '2026-06-26';
const author = 'ToolStep Team';
---

<!doctype html>
