      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL('/', Astro.site).toString() },
        { "@type": "ListItem", "position": 2, "name": "Reviews", "item": new URL('/reviews/', Astro.site).toString() },
        { "@type": "ListItem", "position": 3, "name": "Best Blue Light Glasses for Screen Work", "item": new URL('/reviews/best-blue-light-glasses/', Astro.site).toString() }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Do blue light glasses actually reduce eye strain?", "acceptedAnswer": { "@type": "Answer", "text": "They can help, but they are not a cure-all. The evidence is strongest for improved sleep when worn in the evening, and many users report less end-of-day dryness. Pairing them with the 20-20-20 rule and proper screen brightness matters more than any single lens coating." } },
        { "@type": "Question", "name": "Will 95% blue light blocking change how colors look?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. High-blocking lenses add a noticeable amber tint to screens. If you do color-critical work like photo editing, choose a lower-blocking lens (around 30-40%) that preserves color accuracy, and reserve the 95% pair for evening use." } },
