];
const bestFor = [
  'Budget buyers who want a motorized standing desk under $350 without sacrificing too much',
  'First standing desk users upgrading from a fixed desk and willing to tolerate minor wobble',
  'Light-duty setups with a single monitor or laptop plus a keyboard and mouse',
  'Home office workers who sit and stand a few times a day rather than constantly transitioning',
  'Anyone who wants a large 60 by 30 inch desktop without paying a premium for it',
];
