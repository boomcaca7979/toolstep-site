            <td>$199</td>
            <td>15 + 6 touch</td>
            <td>Yes</td>
            <td>Loupedeck</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Max Falcon-8 Macro Pad</td>
            <td>$45</td>
            <td>8</td>
            <td>No</td>
            <td>VIA/QMK</td>
