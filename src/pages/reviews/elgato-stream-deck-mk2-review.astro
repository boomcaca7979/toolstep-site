  <body>
    <Header />
    <main>
      <h1>Elgato Stream Deck MK.2 Review</h1>
      <div class="meta">Updated June 2026 · 12 min read</div>
      <div class="author">By <a href={`/authors/${authorSlug}`}>{author}</a></div>

