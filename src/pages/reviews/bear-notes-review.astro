  { title: 'Best Screen Recorders for Mac', href: '/reviews/best-screen-recorders-mac/', desc: 'Capture tutorials and demos alongside your notes.' },
];

const prevPost = { title: 'Obsidian Review', href: '/reviews/obsidian-review/' };
const nextPost = { title: 'Notion vs Obsidian', href: '/reviews/notion-vs-obsidian/' };
