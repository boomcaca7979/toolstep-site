import RelatedLinks from '../../components/RelatedLinks.astro';

const pageTitle = buildReviewTitle('Bear (Pro subscription)');
const pageDescription = 'We tested the Bear notes app for 60 days. See how the Markdown editor, nested tags, themes, and Bear Pro sync hold up for personal notes and writing.';
const publishDate = '2026-06-26';
const heroImage = heroImg.src;

const ratingValue = 4.5;
const bestPrice = 2.99;
const author = 'ToolStep Team';
const authorSlug = 'toolstep-team';
const lastUpdated = 'June 2026';
const testingDuration = '60 days';
const productsTested = 4;
const productSlug = 'bear-notes-review';
const productName = 'Bear (Pro subscription)';
const brand = 'Shiny Frog';
const pros = [
  'Beautiful Markdown editor with live preview, typography presets, and seven built-in themes',
  'Nested tag system replaces folders — #work/projects/auto organizes notes hierarchically by tag',
  'Bear Pro sync is fast and reliable across iPhone, iPad, and Mac via iCloud',
  'Markdown export to HTML, PDF, and Word docs preserves formatting and code blocks cleanly',
  'Distraction-free writing mode hides the sidebar and toolbar for long-form drafting',
  'Cross-note linking with [[wiki-links]] builds a personal knowledge graph without setup',
  'Free tier covers all core editing and organizing features — Pro only unlocks sync, themes, and export',
];
const cons = [
  'Apple-only — there is no Windows, Android, or web version of Bear',
  'No real-time collaboration or shared notebooks — Bear is a single-user app only',
  'Pro subscription at $2.99/month adds up to $36/year, more than some one-time-purchase alternatives',
  'No database or table support — long structured notes are awkward compared to Notion or Airtable',
  'Tag-based organization can get messy without discipline — there is no enforced folder hierarchy',
  'Export to Markdown strips some Bear-specific syntax, requiring cleanup for cross-app use',
];

const bestFor = [
  'Apple-only users who want a fast, beautiful Markdown notes app for iPhone, iPad, and Mac',
  'Writers and bloggers who draft in Markdown and want live preview and clean export',
  'Personal knowledge workers who prefer tags over folders for organizing notes',
  'Privacy-minded users who want iCloud sync rather than a third-party cloud service',
  'Students and researchers who want wiki-style cross-note links without a steep learning curve',
];
const notFor = [
  'Windows or Android users — Bear is Apple-only with no web version',
  'Teams that need real-time collaboration or shared notebooks — Bear is single-user only',
  'Users who need databases, tables, or kanban boards — Bear is a notes app, not a workspace',
  'Power users who want plugins, API access, or custom templates — Bear has no extension system',
  'Budget buyers who want a one-time purchase — Bear Pro is a $36/year subscription',
];

const faqs = [
  { q: 'Is Bear free to use, or do you need Bear Pro?', a: 'Bear is free to download and use for all core editing and organizing features, including the Markdown editor, nested tags, cross-note linking, and local storage. Bear Pro ($2.99/month or $28/year) unlocks iCloud sync across devices, the extra themes, and export to PDF, HTML, Word, and JPEG. You can use Bear free forever on a single device — Pro is only required if you sync across multiple Apple devices or want the export formats.' },
  { q: 'Does Bear work on Windows or Android?', a: 'No. Bear is Apple-only — it runs on iPhone, iPad, and Mac, and requires iOS 16 or later and macOS 13 or later. There is no Windows app, no Android app, and no web version. The developer, Shiny Frog, has stated that Bear is built on Apple-native frameworks (Swift, Core Data, TextKit) and porting to other platforms would require a full rewrite. If you use Windows or Android, consider Obsidian or Notion instead.' },
  { q: 'How does Bear compare to Obsidian?', a: 'Bear and Obsidian are both Markdown notes apps, but they differ in scope. Bear is simpler and more polished — it feels like a native Apple app with a beautiful editor and tag-based organization. Obsidian is more powerful and extensible — it stores notes as plain Markdown files, supports plugins, and works on Windows, Android, and Linux. Choose Bear if you want a clean, Apple-only writing app; choose Obsidian if you want cross-platform access, plugins, and file-system-level control.' },
  { q: 'Can you use Bear for a second brain or Zettelkasten?', a: 'Yes, with caveats. Bear supports cross-note linking with [[wiki-links]] and a backlinks panel, which is the core of a Zettelkasten system. The tag system also supports hierarchical organization (#ideas/technology/keyboards). However, Bear lacks graph visualization (Obsidian has this), block references, and daily-note templates out of the box. For a lightweight second brain, Bear works well; for a strict Zettelkasten, Obsidian is the more complete tool.' },
  { q: 'Is Bear Pro worth the $2.99/month subscription?', a: 'Yes, if you use Bear on more than one Apple device — the iCloud sync alone justifies the subscription, and it works reliably in our testing. The extra themes and export formats are nice but secondary. If you only use Bear on a single Mac or iPhone, you can stick with the free tier indefinitely. The annual plan ($28/year) saves about $8 compared to monthly billing, so choose annual if you commit.' },
];

const related = [
  { title: 'Notion vs Obsidian', href: '/reviews/notion-vs-obsidian/', desc: 'Two popular alternatives to Bear with different philosophies.' },
  { title: 'Obsidian Review', href: '/reviews/obsidian-review/', desc: 'A free, cross-platform Markdown notes app with plugins.' },
  { title: 'Notion vs Confluence', href: '/reviews/notion-vs-confluence/', desc: 'Team knowledge bases compared.' },
