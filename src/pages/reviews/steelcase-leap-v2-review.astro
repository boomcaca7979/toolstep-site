          <li><a href="#comparison">How It Compares</a></li>
          <li><a href="#buying-advice">Buying Advice</a></li>
          <li><a href="#faq">FAQ</a></li>
        </ol>
      </nav>

      <div class="rating-box">
        <div>
          <div class="score">{ratingValue}<span style="font-size:1.2rem;color:#9a3412">/5</span></div>
