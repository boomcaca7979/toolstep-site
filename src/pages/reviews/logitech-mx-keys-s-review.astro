---
import Header from '../../components/Header.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import heroImg from '../../assets/blog-placeholder-1.jpg';

const pageTitle = 'Logitech MX Keys S Review (2026)';
const pageDescription = 'We tested the Logitech MX Keys S for 60 days. Perfect Stroke keys, smart backlight, Flow cross-computer, USB-C — see if this $109 keyboard is worth it.';
const publishDate = '2026-06-26';
const heroImage = heroImg.src;

const ratingValue = 4.7;
const bestPrice = 109;
const author = 'Toolwise Team';

const faqs = [
  { q: 'Is the Logitech MX Keys S worth $109?', a: 'For most office users, yes. The MX Keys S has the best low-profile typing feel of any keyboard we tested, the smart backlight genuinely extends battery life (10 days per charge), and Flow cross-computer control is a game-changer for multi-machine setups. The only reason to skip it is if you specifically want mechanical switches — in that case, see our Keychron K8 review.' },
  { q: 'Is the MX Keys S mechanical or membrane?', a: 'Neither — it uses scissor switches, the same mechanism as laptop keyboards and the Apple Magic Keyboard. This gives it a low-profile feel with shorter travel (1.8 mm) than mechanical keyboards (4 mm). It is quieter than mechanical keyboards and preferred by many office users who find mechanical keyboards too tall or too loud.' },
  { q: 'How does Logitech Flow work on the MX Keys S?', a: 'Flow lets you control two computers with a single keyboard and mouse, even switching the cursor between screens by moving it off the edge of one display onto the other. You can copy text on one computer and paste it on the other. It works on Windows and macOS, requires Logitech Options+ software on both machines, and needs both computers on the same network.' },
  { q: 'What is the difference between MX Keys and MX Keys S?', a: 'The MX Keys S is the 2023 successor to the original MX Keys. Key upgrades: a quieter typing mechanism (29% reduction in typing noise), a sensor-based smart backlight that turns on when your hands approach, and improved battery life (10 days versus 5 days on the original). If you have the original MX Keys, the upgrade is not necessary — but for new buyers, always get the S.' },
  { q: 'Does the MX Keys S work with Mac and Windows?', a: 'Yes. The keyboard includes dual-printed keycaps with both Mac and Windows layouts, and the Logitech Options+ software lets you remap any key. We tested it on macOS, Windows, iPadOS, and Android without any compatibility issues. The Fn row works correctly on both Mac and Windows, including media controls and screen brightness.' },
];

const related = [
  { title: 'Best Office Mechanical Keyboard', href: '/reviews/best-office-mechanical-keyboard/', desc: 'Our full roundup of mechanical alternatives.' },
  { title: 'Keychron K8 Review', href: '/reviews/keychron-k8-review/', desc: 'The mechanical keyboard alternative at $84.' },
  { title: 'Logitech MX Master 3S Review', href: '/reviews/logitech-mx-master-3s-review/', desc: 'The natural mouse companion to the MX Keys S.' },
  { title: 'Best Mechanical Keyboard for Work', href: '/reviews/best-mechanical-keyboard-work/', desc: 'Broader roundup including premium options.' },
  { title: 'Best Wireless Mouse for Work', href: '/reviews/best-wireless-mouse-work/', desc: 'Complete your wireless office setup.' },
  { title: 'Best Large Desk Pad', href: '/reviews/best-desk-pad-large/', desc: 'A pad protects your desk and reduces noise.' },
];

const prevPost = { title: 'Keychron K8 Review', href: '/reviews/keychron-k8-review/' };
const nextPost = { title: 'Best Wireless Mouse for Productivity', href: '/reviews/best-wireless-mouse-productivity/' };
