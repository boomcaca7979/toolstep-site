      .toc h2 { margin-top: 0; font-size: 1.1rem; }
      .toc ol { padding-left: 1.4rem; margin: 0; }
      .toc li { margin: 0.3rem 0; }
      .toc a { color: #2563eb; text-decoration: none; }
