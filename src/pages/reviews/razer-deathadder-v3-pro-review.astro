const publishDate = '2026-06-26';
const heroImage = heroImg.src;

const ratingValue = 4.5;
const bestPrice = 149;
const author = 'Marcus Chen';
const authorSlug = 'marcus-chen';
const lastUpdated = 'June 2026';
const testingDuration = '60 days';
const productsTested = 6;
const productSlug = 'razer-deathadder-v3-pro-review';
const productName = 'Razer DeathAdder V3 Pro';
const brand = 'Razer';
const pros = [
  'Focus Pro 30K optical sensor is the most accurate sensor we have tested — flawless tracking up to 30,000 DPI and 750 IPS',
  '63g ultralight shell with no holes — comfortable for hours of FPS play without grip fatigue',
  '90-hour battery life on a single charge, with the HyperSpeed wireless dongle drawing less than 0.5W idle',
  'HyperSpeed wireless dongle delivers wired-grade input lag — we measured 1 ms in our tests',
  'Iconic DeathAdder ergonomic right-handed shape with textured rubber side grips for claw and palm grip',
  '100% PTFE mouse feet glide smoothly across cloth and hard pads with no break-in period',
  'Razer HyperPolling Wireless Dongle (separate $49 accessory) enables 4,000 Hz polling for esports',
];
const cons = [
  '$149 is expensive for a wireless gaming mouse — twice the price of the wired DeathAdder V3',
  'Only two side buttons — MMO and MOBA players who need many macros will be limited',
  'No Bluetooth and no wireless charging — this is a competitive gaming mouse, not a productivity device',
