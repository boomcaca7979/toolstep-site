  <body>
    <Header />
    <main>
      <h1>Logitech MX Master 3S Review</h1>
      <div class="meta">Updated June 2026 · 12 min read</div>
      <div class="author">By {author}</div>

      <img src={heroImage} alt="Logitech MX Master 3S mouse close up on a dark desk" class="hero-img" loading="lazy" width="1280" height="720" />

      <nav class="toc" aria-label="Table of contents">
        <h2>Table of Contents</h2>
        <ol>
          <li><a href="#quick-verdict">Quick Verdict</a></li>
          <li><a href="#pros-and-cons">Pros &amp; Cons</a></li>
          <li><a href="#who-should-buy">Who Should Buy This</a></li>
          <li><a href="#detailed-review">Detailed Review</a></li>
          <li><a href="#comparison">How It Compares</a></li>
          <li><a href="#buying-advice">Buying Advice</a></li>
          <li><a href="#faq">FAQ</a></li>
        </ol>
      </nav>

      <div class="rating-box">
        <div>
          <div class="score">{ratingValue}<span style="font-size:1.2rem;color:#9a3412">/5</span></div>
          <div class="stars">★★★★★</div>
        </div>
