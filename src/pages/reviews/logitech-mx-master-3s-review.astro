import Footer from '../../components/Footer.astro';
import heroImg from '../../assets/blog-placeholder-3.jpg';

const pageTitle = 'Logitech MX Master 3S Review (2026)';
const pageDescription = 'We tested the Logitech MX Master 3S for 60 days. See how the MagSpeed scroll, 8000 DPI sensor, quiet clicks and Flow hold up to daily work.';
const publishDate = '2026-06-26';
const heroImage = heroImg.src;

const ratingValue = 4.8;
const bestPrice = 99;
const author = 'Toolwise Team';

const faqs = [
  { q: 'Is the MX Master 3S worth it over the MX Master 3?', a: 'Yes, if you value quiet clicks or work on glass. The 3S adds 90% quieter clicks and a sensor that tracks on glass. If you already own the MX Master 3 and use a desk pad, the upgrade is hard to justify — the shape, battery, and scroll wheel are essentially identical.' },
  { q: 'Does the MX Master 3S work on Mac and Windows?', a: 'Yes. It works on both platforms over Bluetooth or the included Logi Bolt receiver. Logi Options+ is available for Mac and Windows. Flow works between a Mac and a Windows PC, including clipboard and file drag-and-drop across the local network.' },
  { q: 'How heavy is the Logitech MX Master 3S?', a: 'It weighs 141 grams. That is heavier than a typical gaming mouse, but the weight helps it glide predictably across a desk pad. Some users find it slightly heavy at first, but after a few days of adjustment most people stop noticing.' },
  { q: 'Can you replace the battery in the MX Master 3S?', a: 'No, the battery is sealed inside the mouse. Logitech rates it for 70 days per charge, and ours has held a charge reliably for 60-plus days after 60 days of ownership. The battery is rated for several years of charge cycles under normal use.' },
  { q: 'Does the MX Master 3S work with iPad and iPhone?', a: 'Yes, over Bluetooth. It pairs with iPads and iPhones that support mouse input (iPadOS 13.4 and later, iOS 13 and later). Flow is not supported on iOS, but the mouse works as a standard pointing device. The side buttons and thumb wheel map differently on iOS.' },
];

const related = [
  { title: 'Best Wireless Mouse for Productivity', href: '/reviews/best-wireless-mouse-productivity/', desc: 'How the 3S stacks up against 8 other mice.' },
  { title: 'Logitech MX Keys S Review', href: '/reviews/logitech-mx-keys-s-review/', desc: 'The keyboard built to pair with it.' },
  { title: 'Keychron K8 Review', href: '/reviews/keychron-k8-review/', desc: 'A wireless mechanical keyboard alternative.' },
  { title: 'Best Wireless Mouse for Work', href: '/reviews/best-wireless-mouse-work/', desc: 'More office-focused mouse options.' },
  { title: 'Best Large Desk Pad', href: '/reviews/best-desk-pad-large/', desc: 'A consistent surface makes any mouse better.' },
  { title: 'Best Laptop Stand for Desk', href: '/reviews/best-laptop-stand-desk/', desc: 'Match your screen height to your hand.' },
];

const prevPost = { title: 'Best Wireless Mouse for Productivity', href: '/reviews/best-wireless-mouse-productivity/' };
const nextPost = { title: 'Best USB-C Dock for MacBook', href: '/reviews/best-usbc-dock-macbook/' };
