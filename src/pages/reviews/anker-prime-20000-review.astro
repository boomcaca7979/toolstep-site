const faqs = [
  { q: 'Can you take the Anker Prime 20000 on a plane?', a: 'Yes, but only as carry-on luggage. The Anker Prime 20000 has a 20000mAh capacity at 3.7V nominal, which equals 74 watt-hours (Wh). FAA rules and most international airline policies allow lithium-ion batteries up to 100 Wh in carry-on baggage, but prohibit them in checked luggage. You can carry the Anker Prime 20000 onto a plane, but you cannot pack it in a checked bag. Always confirm with your airline before flying, as some carriers have stricter rules.' },
