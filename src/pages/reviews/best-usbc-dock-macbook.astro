        <thead>
          <tr>
            <th>Dock</th>
            <th>Price</th>
            <th>Type</th>
            <th>Charging</th>
            <th>Dual 4K@60Hz</th>
            <th>Ports</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>CalDigit TS4</strong></td>
            <td>$399</td>
            <td>Thunderbolt 4</td>
            <td>98W</td>
            <td>Yes</td>
            <td>18</td>
          </tr>
