const brand = 'BenQ';
const pros = [
  'Asymmetric optics produce zero screen reflection, even on glossy panels',
  'Wireless knob is rechargeable via USB-C and runs roughly 40 days per charge',
  'Auto-dimming sensor matched our manual brightness choices in 8 of 10 scenarios',
  'Color temperature tunable from 2700K warm to 6500K cool in 100K steps',
  'Curved-monitor adapter included in the box, no extra purchase',
  'USB-C input means no proprietary power brick to lose',
];
const cons = [
  '$129 is steep — $30 more than the already-excellent ScreenBar Plus',
  'The wireless knob is magnetic and can be knocked off the desk by accident',
  'Auto-dimming occasionally dips too low in mixed afternoon-and-lamp light',
  'No physical power button on the bar itself — you must use the knob',
  'Cable is USB-A to USB-C; USB-C only monitors need their own cable',
];
const bestFor = [
  'Remote workers who write or code at a monitor after sunset every day',
  'Anyone with a curved or glossy ultrawide panel that reflects everything',
  'Users who want one-touch brightness without reaching for an in-line dial',
  'People who already own a Desk Bar Plus and want auto-dimming added',
  'Video editors and designers who need a tunable 2700K-6500K range',
];
const notFor = [
  'You only work during daylight hours — a desk lamp is half the price',
  'Your monitor is mounted on an articulating arm with no top edge to clip onto',
  'You cannot justify $129 when the original ScreenBar Plus is $99',
  'You use a laptop-only setup with no external monitor',
];

const faqs = [
  { q: 'Does the BenQ ScreenBar Halo fit on a curved monitor?', a: 'Yes. BenQ ships the Halo with a curved-monitor adapter that clips onto displays up to 1.5 inches thick, including most 1000R and 1500R ultrawides. We tested it on a 34-inch 1800R ultrawide and it sat flush without sagging over three months of daily use.' },
  { q: 'How does the wireless knob work?', a: 'The knob is a Bluetooth-powered rechargeable puck that pairs with the light bar magnetically. You rotate it to change brightness (15 steps) and press it to toggle power. It snaps onto the bar for charging via a USB-C contact pad and runs for roughly 40 days between charges.' },
  { q: 'Does the auto-dimming sensor actually help?', a: 'In our tests it matched our manual adjustments within 100 lux in 8 out of 10 lighting scenarios. It uses an ambient sensor mounted on the front of the bar to read desk lux and adjusts brightness every few seconds. You can disable it by holding the knob if you prefer a fixed level.' },
  { q: 'Is the BenQ ScreenBar Halo worth it over cheaper alternatives?', a: 'For most people yes. The asymmetric optics alone prevent screen reflections that every $30 generic bar we tested caused. The wireless knob and auto-dimming push the price to $129, which is steep — if those two features do not appeal to you, the original ScreenBar Plus at $99 is a better value.' },
  { q: 'Can you use the ScreenBar Halo with a USB-C phone charger?', a: 'Yes. The bar draws 5V 1A from any standard USB-A or USB-C port, including phone chargers and monitor USB hubs. BenQ includes a USB-A to USB-C cable in the box, and you can swap in any USB-C cable if your monitor only has USB-C ports.' },
];

const related = [
