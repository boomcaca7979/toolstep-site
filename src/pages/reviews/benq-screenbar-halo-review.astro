  { title: 'Best Desk Lamp for Eye Care', href: '/reviews/best-desk-lamp-eye-care/', desc: 'Prefer a traditional lamp? These made the cut.' },
  { title: 'Best Monitor Riser for Desk', href: '/reviews/best-monitor-riser-desk/', desc: 'Lift your monitor to match the Halo height.' },
  { title: 'Best Blue Light Glasses', href: '/reviews/best-blue-light-glasses/', desc: 'Pair your light with eye protection.' },
  { title: 'Best Large Desk Pad', href: '/reviews/best-desk-pad-large/', desc: 'A matte pad reduces Halo reflection.' },
  { title: 'Best Standing Desk Converter', href: '/reviews/best-standing-desk-converter/', desc: 'Convert any desk into a sit-stand setup.' },
];

const prevPost = { title: 'Best Monitor Light Bar', href: '/reviews/best-monitor-light-bar/' };
const nextPost = { title: 'Best Webcam for Remote Work', href: '/reviews/best-webcam-remote-work/' };
