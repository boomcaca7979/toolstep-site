        <thead>
          <tr>
            <th>Desk</th>
            <th>Price</th>
            <th>Capacity</th>
            <th>Max Height</th>
            <th>Stability (1-10)</th>
            <th>Warranty</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Uplift V2</strong></td>
            <td>$595+</td>
            <td>355 lbs</td>
            <td>50.5 in</td>
            <td>10</td>
            <td>10 years</td>
          </tr>
          <tr>
