---
import PageLayout from '../../components/PageLayout.astro';
import { authors } from '../../data/authors';
import { reviews } from '../../data/reviews';

const pageTitle = 'Authors — ToolStep Review Team';
const pageDescription = 'Meet the ToolStep reviewers. Each author has a dedicated page with their bio, testing equipment, and review experience.';
const lastUpdated = 'June 2026';

// Helper to get review count for display
function getReviewCount(authorSlug: string): number {
  const author = authors.find(a => a.slug === authorSlug);
  return author?.reviews.length || 0;
}
---

<PageLayout
  title="Our Authors"
  description={pageDescription}
  subtitle="Every review on ToolStep is written by a real, accountable person. Meet them."
  lastUpdated={lastUpdated}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Authors' },
  ]}
>
  <p>
    Our authors are domain experts, not generalist content writers. Each reviewer specializes in a specific product category and has years of hands-on testing experience. Click any author to see their full profile, testing equipment, and published reviews.
  </p>

  <div class="authors-grid">
    {authors.map((author) => (
      <a href={`/authors/${author.slug}`} class="author-card">
        <img src={author.avatar} alt={`${author.name} portrait`} loading="lazy" width="100" height="100" />
        <div class="author-info">
          <h2>{author.name}</h2>
          <p class="author-role">{author.role}</p>
          <p class="author-bio">{author.bio.split('.')[0]}.</p>
          <div class="author-stats">
            <span class="stat">
              <strong>{getReviewCount(author.slug)}</strong> reviews
            </span>
            <span class="stat">
              <strong>{author.expertise.length}</strong> expertise areas
            </span>
          </div>
          <div class="author-expertise">
            {author.expertise.map((exp) => (
              <span class="expertise-tag">{exp}</span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>
</PageLayout>

<style>
  .authors-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 2rem 0;
  }
  .author-card {
    display: flex;
    gap: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .author-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }
  .author-card img {
    border-radius: 50%;
    width: 100px;
    height: 100px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .author-info {
    min-width: 0;
    flex: 1;
  }
  .author-info h2 {
    font-size: 1.3rem;
    margin: 0 0 0.2rem;
    color: rgb(var(--black));
  }
  .author-role {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .author-bio {
    font-size: 0.92rem;
    color: rgb(var(--gray-dark));
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }
  .author-stats {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .author-stats .stat {
    font-size: 0.82rem;
    color: rgb(var(--gray));
  }
  .author-stats .stat strong {
    color: rgb(var(--black));
    font-size: 1rem;
  }
  .author-expertise {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .expertise-tag {
    background: rgba(var(--accent-rgb), 0.08);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 12px;
  }
  @media (max-width: 600px) {
    .author-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .author-expertise {
      justify-content: center;
    }
  }
</style>
