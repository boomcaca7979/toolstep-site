---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const pageTitle = `About ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={SITE_DESCRIPTION} />
		<style>
			.about-wrap {
				max-width: 720px;
				margin: 0 auto;
				padding: 48px 24px;
				min-height: calc(100vh - 200px);
			}
			.about-wrap h1 {
				font-size: 2.2em;
				margin-bottom: 24px;
			}
			.about-wrap h2 {
				font-size: 1.4em;
				margin-top: 36px;
				margin-bottom: 14px;
				color: rgb(var(--black));
			}
			.about-wrap p,
			.about-wrap li {
				font-size: 17px;
				line-height: 1.8;
				color: rgb(var(--gray-dark));
			}
			.about-wrap ul {
				margin-bottom: 16px;
				padding-left: 24px;
			}
			.about-wrap li {
				margin-bottom: 10px;
			}
			.about-wrap a {
				color: var(--accent);
				text-decoration: underline;
			}
			.contact-box {
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 12px;
				padding: 24px;
				margin-top: 32px;
				box-shadow: var(--card-shadow);
			}
			.contact-box h2 {
				margin-top: 0;
			}
			.email-link {
				font-weight: 600;
			}
			.mission-box {
				background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.08), rgba(var(--accent-rgb), 0.03));
				border: 1px solid rgba(var(--accent-rgb), 0.15);
				border-radius: 12px;
				padding: 24px;
				margin-bottom: 32px;
			}
			.mission-box p {
				margin: 0;
				font-size: 18px;
			}
			@media (max-width: 720px) {
				.about-wrap {
					padding: 32px 16px;
				}
				.about-wrap h1 {
					font-size: 1.8em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="about-wrap">
			<h1>About ToolWise</h1>

			<div class="mission-box">
				<p>
					<strong>ToolWise</strong> is a curated directory of the best online tools for productivity, design, AI, and creativity. We cut through the noise to help you find the right tool for the job — fast.
				</p>
			</div>

			<h2>What We Do</h2>
			<p>
				Every day, dozens of new apps and online tools launch. Sorting through them is exhausting. ToolWise exists to solve that problem. We personally test every tool before it appears on our site, evaluate it against real-world use cases, and present our findings in honest, jargon-free reviews.
			</p>
			<p>
				Whether you need to compress an image, edit a PDF, record your screen, or draft a blog post with AI — we have tested the options and will point you to the best one.
			</p>

			<h2>Our Review Standards</h2>
			<p>Every tool on ToolWise is evaluated against the same criteria:</p>
			<ul>
				<li>
					<strong>Hands-on testing</strong> — We use each tool for real tasks, not just a quick click-through. If it is a PDF editor, we edit PDFs. If it is a screen recorder, we record screens.
				</li>
				<li>
					<strong>Free tier fairness</strong> — We evaluate what you actually get for free, not just the paid features. Many of our readers are students, freelancers, and small teams with tight budgets.
				</li>
				<li>
					<strong>Transparency</strong> — We disclose affiliate relationships and never let them influence our ratings. Our "Editor's Pick" badges are based on testing, not commissions.
				</li>
				<li>
					<strong>Real user needs</strong> — We rate tools based on who they are actually for. A professional video editor and a casual screen recorder serve different audiences, and we review them accordingly.
				</li>
			</ul>

			<h2>Why Trust Us</h2>
			<p>
				ToolWise is independently operated. We do not accept paid placement in our directory, and we do not let brands preview or edit our reviews before publication. Our editorial team has collectively tested hundreds of productivity and creative tools over the past decade across design, development, writing, and video production.
			</p>

			<div class="contact-box">
				<h2>Get in Touch</h2>
				<p>
					Have a tool suggestion? Found an outdated review? Want to partner with us? We would love to hear from you.
				</p>
				<p>
					📧 <a href="mailto:hello@toolwise.com" class="email-link">hello@toolwise.com</a>
				</p>
				<p style="margin-top: 12px; font-size: 15px; color: rgb(var(--gray));">
					For privacy-related inquiries, please visit our <a href="/privacy">Privacy Policy</a> page.
				</p>
			</div>
		</div>
		<Footer />
	</body>
</html>
