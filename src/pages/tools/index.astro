---
import PageLayout from '../../components/PageLayout.astro';
import { tools, categories } from '../../data/tools';

const pageTitle = 'Tools Directory';
const pageDescription = 'Browse our complete directory of tested tools across all categories.';
const lastUpdated = 'June 2026';

// Category id -> display name
const categoryName: Record<string, string> = {};
for (const cat of categories) {
  categoryName[cat.id] = cat.name;
}

// Group tools by category preserving data order
const groups: { id: string; name: string; items: typeof tools }[] = [];
for (const tool of tools) {
  let group = groups.find((g) => g.id === tool.category);
  if (!group) {
    group = { id: tool.category, name: categoryName[tool.category] || tool.category, items: [] };
    groups.push(group);
  }
  group.items.push(tool);
}

function renderStars(rating: number): string {
  const full = Math.floor(rating);
  const empty = 5 - full;
  return '★'.repeat(full) + '☆'.repeat(empty);
}
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  subtitle="Every tool we have tested and rated, organized by category. Click any card to read the full review."
  lastUpdated={lastUpdated}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Tools' },
  ]}
>
  <div class="tools-categories">
    {groups.map((group) => (
      <section class="category-section">
        <h2>
          {group.name}
          <span class="category-count">{group.items.length}</span>
        </h2>
        <div class="tools-grid">
          {group.items.map((tool) => (
            <a href={`/tools/${tool.id}/`} class="tool-card">
              <div class="card-head">
                <div class="card-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={tool.icon} />
                  </svg>
                </div>
                <div class="card-title-wrap">
                  <div class="card-title">{tool.name}</div>
                  <div class="card-rating">
                    <span class="stars" aria-hidden="true">{renderStars(tool.rating)}</span>
                    <span class="rating-num">{tool.rating}</span>
                  </div>
                </div>
              </div>
              <div class="card-desc">{tool.description}</div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</PageLayout>

<style>
  .tools-categories {
    margin: 1rem 0;
  }
  .category-section {
    margin-bottom: 2.5rem;
  }
  .category-section h2 {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.5rem;
    margin: 0 0 1rem;
    color: rgb(var(--black));
  }
  .category-count {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgb(var(--gray));
    background: rgba(var(--gray-light), 60%);
    padding: 2px 10px;
    border-radius: 12px;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .tool-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .tool-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .card-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(var(--accent-rgb), 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }
  .card-icon svg {
    width: 22px;
    height: 22px;
  }
  .card-title-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: rgb(var(--black));
    line-height: 1.3;
  }
  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
  }
  .card-rating .stars {
    color: #f5a623;
    letter-spacing: 1px;
  }
  .card-rating .rating-num {
    color: rgb(var(--gray));
    font-weight: 600;
  }
  .card-desc {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    line-height: 1.5;
    flex: 1;
  }
  @media (max-width: 720px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
