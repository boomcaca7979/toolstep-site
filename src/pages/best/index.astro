---
import PageLayout from '../../components/PageLayout.astro';
import { bestData } from '../../data/best';

const pageTitle = 'Best — ToolStep Best Product Roundups';
const pageDescription = 'Our top 10 product roundups tested by our team. Standing desks, chairs, keyboards, mice, monitors, docks, and more.';
const lastUpdated = 'June 2026';

// Group by category preserving order
const categories: { name: string; color: string; items: typeof bestData }[] = [];
for (const entry of bestData) {
  let group = categories.find(c => c.name === entry.category);
  if (!group) {
    group = { name: entry.category, color: entry.color, items: [] };
    categories.push(group);
  }
  group.items.push(entry);
}
---

<PageLayout
  title="Best Products"
  description={pageDescription}
  subtitle="100 in-depth best product roundups across hardware and software. Each page ranks the top 10 picks with ratings, pros/cons, and FAQ."
  lastUpdated={lastUpdated}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Best' },
  ]}
>
  <div class="best-categories">
    {categories.map((cat) => (
      <section class="category-section">
        <h2>
          <span class="category-dot" style={`background: ${cat.color}`}></span>
          {cat.name}
          <span class="category-count">{cat.items.length}</span>
        </h2>
        <div class="best-grid">
          {cat.items.map((entry) => (
            <a href={`/best/${entry.slug}/`} class="best-card">
              <div class="card-title">{entry.title}</div>
              <div class="card-desc">{entry.description}</div>
              <div class="card-top-pick">
                <span class="top-label">Top Pick:</span>
                <span class="top-name">{entry.products[0]?.name || '—'}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</PageLayout>

<style>
  .best-categories {
    margin: 1rem 0;
  }
  .category-section {
    margin-bottom: 2.5rem;
  }
  .category-section h2 {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.5rem;
    margin: 0 0 1rem;
    color: rgb(var(--black));
  }
  .category-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .category-count {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgb(var(--gray));
    background: rgba(var(--gray-light), 60%);
    padding: 2px 10px;
    border-radius: 12px;
    margin-left: 0.25rem;
  }
  .best-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .best-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .best-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }
  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: rgb(var(--black));
    line-height: 1.3;
  }
  .card-desc {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    line-height: 1.5;
    flex: 1;
  }
  .card-top-pick {
    margin-top: 0.5rem;
    font-size: 0.82rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .card-top-pick .top-label {
    color: rgb(var(--gray));
    font-weight: 600;
  }
  .card-top-pick .top-name {
    color: var(--accent);
    font-weight: 700;
  }
  @media (max-width: 720px) {
    .best-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
