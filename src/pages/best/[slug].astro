---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AdUnit from '../../components/ads/AdUnit.astro';
import { getBestEntries, getBestEntryBySlug } from '../../data/content';
import { authors } from '../../data/authors';
import { buildBestTitle } from '../../utils/seo';
import { mapCategoryToSlug } from '../../data/category-map';
import { getCategoryBySlug } from '../../data/categories';
import { getRelatedForBest } from '../../lib/related';

export function getStaticPaths() {
  return getBestEntries().map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const author = authors.find(a => a.slug === entry.authorSlug);
const authorName = author?.name || 'ToolStep Team';

const publishDate = '2026-06-26';
const pageUrl = new URL(`/best/${entry.slug}/`, Astro.site).toString();

// Find prev/next for navigation
const allBests = getBestEntries();
const idx = allBests.findIndex(e => e.slug === entry.slug);
const prevEntry = idx > 0 ? allBests[idx - 1] : null;
const nextEntry = idx < allBests.length - 1 ? allBests[idx + 1] : null;

// Resolve related bests
const relatedBestItems = entry.relatedBests
  .map(slug => getBestEntryBySlug(slug))
  .filter((b): b is NonNullable<typeof b> => b !== undefined)
  .slice(0, 4);

// Resolve canonical category for internal linking
const canonicalCatSlug = mapCategoryToSlug(entry.category, entry.title);
const categoryPage = canonicalCatSlug ? getCategoryBySlug(canonicalCatSlug) : null;
const categoryLink = categoryPage ? `/category/${categoryPage.slug}/` : null;
const categoryLabel = categoryPage ? categoryPage.pluralName : entry.category;

// Related content graph (reviews, comparisons) via shared matching logic
const relatedGraph = getRelatedForBest(entry.slug, entry.products.map(p => p.name), entry.category);

// Stars helper
function stars(rating: number): string {
  return '★★★★★'.slice(0, Math.round(rating)) + '☆☆☆☆☆'.slice(0, 5 - Math.round(rating));
}

// Average rating
const avgRating = (entry.products.reduce((sum, p) => sum + p.rating, 0) / entry.products.length).toFixed(1);

// TOC sections
const tocSections = [
  { id: 'top-picks', label: 'Top 10 Picks' },
  { id: 'comparison', label: 'Comparison Table' },
  ...entry.products.slice(0, 3).map((p, i) => ({ id: `pick-${i + 1}`, label: `${i + 1}. ${p.name}` })),
  { id: 'pros-cons', label: 'Pros & Cons' },
  { id: 'faq', label: 'FAQ' },
];

// === Schemas ===
// Note: /best/ pages are Best list / buying guide pages, NOT product detail pages.
// We use Article + ItemList schemas instead of Product/Review to comply with
// Google Rich Results requirements and avoid the "offers/review/aggregateRating" error.

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: entry.title,
  description: entry.description,
  numberOfItems: entry.products.length,
  itemListElement: entry.products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: pageUrl,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: entry.faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'Best', item: new URL('/best/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: entry.title, item: pageUrl },
  ],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.title,
  description: entry.description,
  datePublished: publishDate,
  dateModified: publishDate,
  author: { '@type': 'Person', name: authorName },
  publisher: {
    '@type': 'Organization',
    name: 'ToolStep',
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={buildBestTitle(entry.title)} description={entry.description} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <style>
      .best-page {
        max-width: 960px;
        margin: 0 auto;
        padding: 48px 24px 64px;
        min-height: calc(100vh - 200px);
      }
      .breadcrumb {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.3rem;
        font-size: 0.82rem;
        color: rgb(var(--gray));
        margin-bottom: 1.5rem;
      }
      .breadcrumb a {
        color: rgb(var(--gray));
        text-decoration: none;
      }
      .breadcrumb a:hover {
        color: var(--accent);
      }
      .breadcrumb .sep {
        color: rgb(var(--gray-light));
      }
      .breadcrumb .current {
        color: rgb(var(--gray-dark));
        font-weight: 600;
      }

      /* Layout */
      .layout {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 2rem;
      }
      .main-col {
        min-width: 0;
      }
      .toc-col {
        position: sticky;
        top: 80px;
        align-self: start;
      }
      .toc {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 12px;
        padding: 1rem 1.25rem;
      }
      .toc-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgb(var(--gray));
        margin: 0 0 0.5rem;
      }
      .toc ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .toc li {
        padding: 0.2rem 0;
      }
      .toc a {
        font-size: 0.82rem;
        color: rgb(var(--gray-dark));
        text-decoration: none;
        line-height: 1.4;
        display: block;
        padding: 0.15rem 0;
      }
      .toc a:hover {
        color: var(--accent);
      }

      /* Hero */
      .hero {
        margin-bottom: 2rem;
      }
      .hero .category-tag {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 4px 12px;
        border-radius: 12px;
        margin-bottom: 0.75rem;
        color: white;
      }
      .hero h1 {
        font-size: 2.2rem;
        line-height: 1.2;
        margin: 0 0 0.75rem;
        color: rgb(var(--black));
      }
      .hero .desc {
        font-size: 1.1rem;
        color: rgb(var(--gray));
        line-height: 1.6;
        margin: 0 0 1rem;
      }
      .hero-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.85rem;
        color: rgb(var(--gray));
        margin-top: 1rem;
        flex-wrap: wrap;
      }
      .hero-meta a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }
      .hero-meta .dot {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: rgb(var(--gray-light));
      }
      .hero-stats {
        display: flex;
        gap: 1.5rem;
        margin-top: 1rem;
        padding: 1rem;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 12px;
      }
      .hero-stat {
        text-align: left;
      }
      .hero-stat .num {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--accent);
        line-height: 1;
      }
      .hero-stat .label {
        font-size: 0.75rem;
        color: rgb(var(--gray));
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 600;
        margin-top: 0.25rem;
      }

      /* Intro */
      .intro {
        background: rgba(var(--accent-rgb), 0.03);
        border-left: 4px solid var(--accent);
        padding: 1rem 1.25rem;
        border-radius: 0 8px 8px 0;
        font-size: 0.98rem;
        line-height: 1.7;
        color: rgb(var(--gray-dark));
        margin: 1.5rem 0 2rem;
      }

      h2 {
        font-size: 1.6rem;
        margin: 2.5rem 0 1rem;
        color: rgb(var(--black));
        scroll-margin-top: 80px;
      }

      /* Top picks list */
      .picks-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin: 1rem 0;
      }
      .pick-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 12px;
        padding: 1.25rem;
        display: grid;
        grid-template-columns: 60px 1fr auto;
        gap: 1rem;
        align-items: start;
      }
      .pick-rank {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--accent);
        line-height: 1;
        text-align: center;
      }
      .pick-rank.gold { color: #f59e0b; }
      .pick-rank.silver { color: #94a3b8; }
      .pick-rank.bronze { color: #b45309; }
      .pick-info h3 {
        font-size: 1.15rem;
        margin: 0 0 0.3rem;
        color: rgb(var(--black));
      }
      .pick-info .pick-brand {
        font-size: 0.78rem;
        font-weight: 600;
        color: rgb(var(--gray));
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.5rem;
      }
      .pick-info .pick-summary {
        font-size: 0.9rem;
        color: rgb(var(--gray-dark));
        line-height: 1.6;
        margin: 0 0 0.5rem;
      }
      .pick-info .pick-pros-cons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        margin-top: 0.5rem;
      }
      .pick-pros, .pick-cons {
        font-size: 0.82rem;
      }
      .pick-pros strong { color: #059669; display: block; margin-bottom: 0.2rem; }
      .pick-cons strong { color: #dc2626; display: block; margin-bottom: 0.2rem; }
      .pick-pros ul, .pick-cons ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .pick-pros li, .pick-cons li {
        padding-left: 1rem;
        position: relative;
        line-height: 1.5;
        color: rgb(var(--gray-dark));
        margin-bottom: 0.15rem;
      }
      .pick-pros li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: #059669;
        font-weight: bold;
      }
      .pick-cons li::before {
        content: '✗';
        position: absolute;
        left: 0;
        color: #dc2626;
        font-weight: bold;
      }
      .pick-meta {
        text-align: right;
        border-left: 1px solid var(--card-border);
        padding-left: 1rem;
      }
      .pick-rating {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--accent);
        line-height: 1;
      }
      .pick-rating .out {
        font-size: 0.85rem;
        color: rgb(var(--gray));
        font-weight: 500;
      }
      .pick-stars {
        color: #f59e0b;
        letter-spacing: 1px;
        font-size: 0.95rem;
        margin-top: 0.2rem;
      }
      .pick-price {
        font-size: 1.1rem;
        font-weight: 700;
        color: rgb(var(--black));
        margin-top: 0.5rem;
      }

      /* Comparison table */
      .compare-table-wrap {
        overflow-x: auto;
        margin: 1rem 0;
      }
      .compare-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
        min-width: 600px;
      }
      .compare-table th,
      .compare-table td {
        border: 1px solid var(--card-border);
        padding: 0.6rem 0.75rem;
        text-align: left;
      }
      .compare-table th {
        background: rgba(var(--gray-light), 40%);
        font-weight: 700;
        color: rgb(var(--black));
      }
      .compare-table th.rank-col { width: 50px; }
      .compare-table td.rank {
        font-weight: 800;
        text-align: center;
        color: var(--accent);
      }
      .compare-table td.name {
        font-weight: 700;
        color: rgb(var(--black));
      }
      .compare-table td.rating {
        text-align: center;
        font-weight: 700;
      }
      .compare-table td.price {
        text-align: right;
        font-weight: 600;
        white-space: nowrap;
      }
      .compare-table tr:hover td {
        background: rgba(var(--accent-rgb), 0.02);
      }

      /* Pros & Cons summary section */
      .pros-cons-summary {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
        margin: 1rem 0;
      }
      .pc-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 10px;
        padding: 1rem;
      }
      .pc-card h4 {
        font-size: 0.95rem;
        margin: 0 0 0.5rem;
        color: rgb(var(--black));
      }
      .pc-card .rating-row {
        font-size: 0.85rem;
        color: rgb(var(--gray));
        margin-bottom: 0.5rem;
      }
      .pc-card .pros-line, .pc-card .cons-line {
        font-size: 0.82rem;
        line-height: 1.5;
        color: rgb(var(--gray-dark));
        margin-bottom: 0.3rem;
      }
      .pc-card .pros-line { color: #059669; }
      .pc-card .cons-line { color: #dc2626; }

      /* FAQ */
      .faq-list {
        margin: 1rem 0;
      }
      .faq-list details {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 8px;
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
      }
      .faq-list summary {
        font-weight: 700;
        color: rgb(var(--black));
        cursor: pointer;
        font-size: 0.98rem;
      }
      .faq-list details[open] summary {
        margin-bottom: 0.75rem;
      }
      .faq-list details p {
        margin: 0;
        font-size: 0.92rem;
        line-height: 1.7;
        color: rgb(var(--gray-dark));
      }

      /* Related */
      .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 0.75rem;
        margin: 1rem 0;
      }
      .related-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 10px;
        padding: 0.85rem 1rem;
        text-decoration: none;
        color: var(--accent);
        font-weight: 600;
        font-size: 0.9rem;
        transition: box-shadow 0.15s ease, transform 0.15s ease;
      }
      .related-card:hover {
        box-shadow: var(--card-shadow);
        transform: translateY(-1px);
      }
      .related-card .cat {
        font-size: 0.72rem;
        color: rgb(var(--gray));
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.2rem;
      }

      /* Prev / Next nav */
      .nav-links {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin: 2.5rem 0;
      }
      .nav-links a {
        display: block;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        text-decoration: none;
        color: var(--accent);
        font-weight: 600;
        font-size: 0.95rem;
      }
      .nav-links a:hover {
        box-shadow: var(--card-shadow);
      }
      .nav-links .nav-label {
        display: block;
        font-size: 0.75rem;
        color: rgb(var(--gray));
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.25rem;
        font-weight: 600;
      }
      .nav-links .next {
        text-align: right;
      }

      @media (max-width: 880px) {
        .layout {
          grid-template-columns: 1fr;
        }
        .toc-col {
          position: static;
          order: -1;
        }
        .toc {
          padding: 0.75rem 1rem;
        }
      }
      @media (max-width: 640px) {
        .pick-card {
          grid-template-columns: 50px 1fr;
        }
        .pick-meta {
          grid-column: 1 / -1;
          border-left: none;
          border-top: 1px solid var(--card-border);
          padding-left: 0;
          padding-top: 0.75rem;
          text-align: left;
          display: flex;
          gap: 1.5rem;
          align-items: center;
        }
        .pick-info .pick-pros-cons {
          grid-template-columns: 1fr;
        }
        .nav-links {
          grid-template-columns: 1fr;
        }
        .hero h1 {
          font-size: 1.6rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <div class="best-page">
      {/* Breadcrumb */}
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <a href="/best/">Best</a>
        <span class="sep">/</span>
        {categoryLink ? (
          <>
            <a href={categoryLink}>{categoryLabel}</a>
            <span class="sep">/</span>
          </>
        ) : null}
        <span class="current">{entry.title}</span>
      </nav>

      <div class="layout">
        <div class="main-col">
          {/* Hero */}
          <div class="hero">
            {categoryLink ? (
              <a href={categoryLink} class="category-tag" style={`background: ${entry.color}`} title={`Browse all ${categoryLabel.toLowerCase()} content`}>{entry.category}</a>
            ) : (
              <span class="category-tag" style={`background: ${entry.color}`}>{entry.category}</span>
            )}
            <h1>{entry.title}</h1>
            <p class="desc">{entry.description}</p>
            <div class="hero-stats">
              <div class="hero-stat">
                <div class="num">{entry.products.length}</div>
                <div class="label">Products Tested</div>
              </div>
              <div class="hero-stat">
                <div class="num">{avgRating}</div>
                <div class="label">Avg Rating</div>
              </div>
              <div class="hero-stat">
                <div class="num">{entry.testingDuration}</div>
                <div class="label">Testing Time</div>
              </div>
            </div>
            <div class="hero-meta">
              <span>By <a href={`/authors/${entry.authorSlug}`}>{authorName}</a></span>
              <span class="dot"></span>
              <span>Updated {entry.lastUpdated}</span>
            </div>
          </div>

          {/* Intro */}
          <div class="intro">{entry.intro}</div>

          <AdSlot position="hero-below" />

          {/* Top 10 Picks */}
          <h2 id="top-picks">Top 10 Picks</h2>
          <div class="picks-list">
            {entry.products.map((p, i) => (
              <>
                <div class="pick-card" id={`pick-${i + 1}`}>
                  <div class={`pick-rank ${i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : ''}`}>{p.rank}</div>
                  <div class="pick-info">
                    <h3>{p.name}</h3>
                    <div class="pick-brand">{p.brand}</div>
                    <p class="pick-summary">{p.summary}</p>
                    <div class="pick-pros-cons">
                      <div class="pick-pros">
                        <strong>Pros</strong>
                        <ul>
                          {p.pros.map(pro => <li>{pro}</li>)}
                        </ul>
                      </div>
                      <div class="pick-cons">
                        <strong>Cons</strong>
                        <ul>
                          {p.cons.map(con => <li>{con}</li>)}
                        </ul>
                      </div>
                    </div>
                  </div>
                  <div class="pick-meta">
                    <div class="pick-rating">{p.rating}<span class="out">/5</span></div>
                    <div class="pick-stars">{stars(p.rating)}</div>
                    <div class="pick-price">${p.price}</div>
                  </div>
                </div>
                {i === 4 && (
                  <AdUnit slot="2222222222" format="horizontal" layout="in-article" />
                )}
              </>
            ))}
          </div>

          {/* Comparison Table */}
          <h2 id="comparison">Comparison Table</h2>
          <div class="compare-table-wrap">
            <table class="compare-table">
              <thead>
                <tr>
                  <th class="rank-col">#</th>
                  <th>Name</th>
                  <th>Brand</th>
                  <th>Rating</th>
                  <th>Price</th>
                </tr>
              </thead>
              <tbody>
                {entry.products.map((p) => (
                  <tr>
                    <td class="rank">{p.rank}</td>
                    <td class="name">{p.name}</td>
                    <td>{p.brand}</td>
                    <td class="rating">
                      {p.rating}/5
                      <div style="font-size:0.75rem; color:#f59e0b;">{stars(p.rating)}</div>
                    </td>
                    <td class="price">${p.price}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <AdSlot position="content-mid" />

          {/* Pros & Cons Summary */}
          <h2 id="pros-cons">Pros & Cons Summary</h2>
          <div class="pros-cons-summary">
            {entry.products.map((p) => (
              <div class="pc-card">
                <h4>{p.name}</h4>
                <div class="rating-row">Rating: {p.rating}/5 · ${p.price}</div>
                <div class="pros-line">+ {p.pros[0]}</div>
                <div class="cons-line">− {p.cons[0]}</div>
              </div>
            ))}
          </div>

          {/* FAQ */}
          <AdUnit slot="3333333333" format="auto" layout="responsive" />

          <h2 id="faq">FAQ</h2>
          <div class="faq-list">
            {entry.faqs.map(faq => (
              <details>
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>

          {/* Related Reviews */}
          {relatedGraph.relatedReviews.length > 0 && (
            <>
              <h2 id="related-reviews">Related Reviews</h2>
              <div class="related-grid">
                {relatedGraph.relatedReviews.map(r => (
                  <a href={r.href} class="related-card">
                    <div class="cat">Review</div>
                    {r.title}
                  </a>
                ))}
              </div>
            </>
          )}

          {/* Related Bests */}
          {relatedBestItems.length > 0 && (
            <>
              <h2 id="related">Related Bests</h2>
              <div class="related-grid">
                {relatedBestItems.map((b) => (
                  <a href={`/best/${b.slug}/`} class="related-card">
                    <div class="cat">{b.category}</div>
                    {b.title}
                  </a>
                ))}
              </div>
            </>
          )}

          {/* Related Comparisons */}
          {relatedGraph.relatedComparisons.length > 0 && (
            <>
              <h2 id="related-comparisons">Related Comparisons</h2>
              <div class="related-grid">
                {relatedGraph.relatedComparisons.map(r => (
                  <a href={r.href} class="related-card">
                    <div class="cat">Compare</div>
                    {r.title}
                  </a>
                ))}
              </div>
            </>
          )}

          {/* Explore Category */}
          {categoryLink && (
            <div style="background: rgba(var(--accent-rgb), 0.03); border: 1px solid rgba(var(--accent-rgb), 0.15); border-radius: 12px; padding: 1.25rem 1.5rem; margin: 2rem 0;">
              <h2 style="margin-top: 0; font-size: 1.2rem;">Explore More {categoryLabel}</h2>
              <p style="margin: 0.5rem 0 0.75rem; color: rgb(var(--gray)); font-size: 0.92rem;">Browse all {categoryLabel.toLowerCase()} reviews, comparisons, and best-of guides on our {categoryLabel} category page.</p>
              <a href={categoryLink} style="color: var(--accent); font-weight: 600; text-decoration: none; font-size: 0.95rem;">View all {categoryLabel.toLowerCase()} →</a>
            </div>
          )}

          {/* Previous / Next */}
          <AdSlot position="content-end" />

          <div class="nav-links">
            {prevEntry ? (
              <a href={`/best/${prevEntry.slug}/`}>
                <span class="nav-label">← Previous</span>
                {prevEntry.title}
              </a>
            ) : <span></span>}
            {nextEntry ? (
              <a href={`/best/${nextEntry.slug}/`} class="next">
                <span class="nav-label">Next →</span>
                {nextEntry.title}
              </a>
            ) : <span></span>}
          </div>
        </div>

        {/* TOC */}
        <aside class="toc-col">
          <nav class="toc" aria-label="Table of contents">
            <div class="toc-label">On this page</div>
            <ul>
              {tocSections.map(s => (
                <li><a href={`#${s.id}`}>{s.label}</a></li>
              ))}
            </ul>
          </nav>
          <AdSlot position="sidebar" />
        </aside>
      </div>
    </div>
    <AdSlot position="mobile-bottom" />
    <Footer />
  </body>
</html>
