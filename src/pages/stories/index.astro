---
import PageLayout from '../../components/PageLayout.astro';
import { storiesData } from '../../data/stories';

const pageTitle = 'Web Stories — ToolStep Visual Stories';
const pageDescription = '50 visual web stories covering hardware reviews, software comparisons, and productivity tips. Swipe through our top picks in 60 seconds.';
const lastUpdated = 'June 2026';

// Group by category preserving order
const categories: { name: string; color: string; items: typeof storiesData }[] = [];
for (const story of storiesData) {
  let group = categories.find(c => c.name === story.category);
  if (!group) {
    group = { name: story.category, color: story.color, items: [] };
    categories.push(group);
  }
  group.items.push(story);
}
---

<PageLayout
  title="Web Stories"
  description={pageDescription}
  subtitle="50 visual stories — swipe through our top picks, comparisons, and buying guides in 60 seconds."
  lastUpdated={lastUpdated}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Stories' },
  ]}
>
  <div class="stories-categories">
    {categories.map((cat) => (
      <section class="category-section">
        <h2>
          <span class="category-dot" style={`background: ${cat.color}`}></span>
          {cat.name}
          <span class="category-count">{cat.items.length}</span>
        </h2>
        <div class="stories-grid">
          {cat.items.map((story) => (
            <a href={`/stories/${story.slug}/`} class="story-card">
              <div class="story-poster">
                <img
                  src={story.poster}
                  alt={story.title}
                  width="270"
                  height="480"
                  loading="lazy"
                  decoding="async"
                />
                <div class="story-overlay">
                  <div class="story-category" style={`background: ${story.color}`}>{story.category}</div>
                  <div class="story-pages-badge">{story.pages.length} slides</div>
                </div>
              </div>
              <div class="story-info">
                <div class="story-title">{story.title}</div>
                <div class="story-desc">{story.description}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</PageLayout>

<style>
  .stories-categories {
    margin: 1rem 0;
  }
  .category-section {
    margin-bottom: 2.5rem;
  }
  .category-section h2 {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.5rem;
    margin: 0 0 1rem;
    color: rgb(var(--black));
  }
  .category-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .category-count {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgb(var(--gray));
    background: rgba(var(--gray-light), 60%);
    padding: 2px 10px;
    border-radius: 12px;
    margin-left: 0.25rem;
  }
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }
  .story-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.15s ease;
  }
  .story-card:hover {
    transform: translateY(-3px);
  }
  .story-poster {
    position: relative;
    aspect-ratio: 9 / 16;
    border-radius: 12px;
    overflow: hidden;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
  }
  .story-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .story-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0.5rem;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, transparent 30%, transparent 70%, rgba(0,0,0,0.5) 100%);
  }
  .story-category {
    align-self: flex-start;
    font-size: 0.68rem;
    font-weight: 700;
    color: white;
    padding: 3px 8px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .story-pages-badge {
    align-self: flex-end;
    font-size: 0.68rem;
    font-weight: 600;
    color: white;
    background: rgba(0, 0, 0, 0.5);
    padding: 3px 8px;
    border-radius: 6px;
    backdrop-filter: blur(4px);
  }
  .story-info {
    padding: 0 0.1rem;
  }
  .story-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: rgb(var(--black));
    line-height: 1.3;
    margin-bottom: 0.15rem;
  }
  .story-desc {
    font-size: 0.78rem;
    color: rgb(var(--gray));
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 720px) {
    .stories-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.75rem;
    }
  }
</style>
